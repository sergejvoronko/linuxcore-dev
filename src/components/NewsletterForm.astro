---
// src/components/NewsletterForm.astro
// Drop this anywhere on the site for an email capture form.
// Hook up to Buttondown, ConvertKit, or any email API in the <script> block.
---

<section class="nl-section">
  <div class="nl-inner">
    <div class="nl-left">
      <div class="nl-number">2,400+</div>
      <div class="nl-sublabel">sysadmins subscribed</div>
    </div>

    <div class="nl-right">
      <h3 class="nl-title">The Weekly <span>Linux Dispatch</span></h3>
      <p class="nl-desc">
        Every Monday: one new tool, one AI automation tip, one config snippet
        you can deploy immediately. No noise. Just signal.
      </p>

      <form class="nl-form" id="nl-form">
        <input
          type="email"
          name="email"
          class="nl-input"
          placeholder="you@domain.dev"
          required
        />
        <button type="submit" class="nl-btn">SUBSCRIBE →</button>
      </form>

      <div class="nl-perks">
        <span>✓ Free Ansible starter pack on signup</span>
        <span>✓ No spam, ever</span>
        <span>✓ Unsubscribe anytime</span>
      </div>

      <p class="nl-success" id="nl-success" style="display:none">
        ✓ You're in! Check your inbox for the free Ansible pack.
      </p>
    </div>
  </div>
</section>

<style>
  .nl-section { background: var(--bg2); border: 1px solid var(--border); }
  .nl-inner {
    max-width: 1100px; margin: 0 auto;
    padding: 48px 40px;
    display: grid; grid-template-columns: 220px 1fr; gap: 48px; align-items: center;
  }
  @media (max-width: 700px) { .nl-inner { grid-template-columns: 1fr; gap: 24px; padding: 28px 20px; } }
  .nl-number { font-family: var(--sans); font-size: 52px; font-weight: 800; color: var(--green); line-height: 1; }
  .nl-sublabel { color: var(--text-dim); font-size: 11px; letter-spacing: 0.1em; margin-top: 4px; }
  .nl-title { font-family: var(--sans); font-size: 22px; font-weight: 800; color: var(--text-bright); margin-bottom: 10px; line-height: 1.2; }
  .nl-title span { color: var(--green); }
  .nl-desc { color: var(--text-dim); font-size: 12px; line-height: 1.7; margin-bottom: 18px; }
  .nl-form { display: flex; gap: 0; margin-bottom: 12px; }
  .nl-input {
    flex: 1; background: var(--bg); border: 1px solid var(--border); border-right: none;
    color: var(--text); padding: 10px 14px; font-family: var(--mono); font-size: 12px; outline: none;
  }
  .nl-input:focus { border-color: var(--green); }
  .nl-input::placeholder { color: var(--text-dim); }
  .nl-btn {
    background: var(--green); color: var(--bg); border: none;
    padding: 10px 18px; font-family: var(--mono); font-size: 12px;
    font-weight: 700; letter-spacing: 0.08em; cursor: pointer; transition: background 0.15s;
  }
  .nl-btn:hover { background: #00ffaa; }
  .nl-perks { display: flex; gap: 14px; flex-wrap: wrap; }
  .nl-perks span { color: var(--text-dim); font-size: 10px; }
  .nl-success { color: var(--green); font-size: 13px; margin-top: 10px; }
</style>

<script>
  const form    = document.getElementById('nl-form') as HTMLFormElement;
  const success = document.getElementById('nl-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value;

    // ── Replace this with your actual email provider ──────────────
    // Buttondown example:
    // await fetch('https://api.buttondown.email/v1/subscribers', {
    //   method: 'POST',
    //   headers: {
    //     Authorization: 'Token YOUR_BUTTONDOWN_API_KEY',
    //     'Content-Type': 'application/json',
    //   },
    //   body: JSON.stringify({ email }),
    // });
    // ─────────────────────────────────────────────────────────────

    // Placeholder — swap with real API call above
    console.log('Subscribe:', email);

    form.style.display = 'none';
    success.style.display = 'block';
  });
</script>
