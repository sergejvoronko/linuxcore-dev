---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="lc-footer">
  <div class="footer-inner">
    <a href="/" class="footer-logo">
      <span class="logo-mark-sm">LC</span>
      <span class="footer-name">linuxcore<span style="color:var(--text-dim)">.dev</span></span>
    </a>

    <nav class="footer-links">
      <a href="/guides">Guides</a>
      <a href="/tools">Tools</a>
      <a href="/scripts">Scripts</a>
      <a href="/newsletter">Newsletter</a>
      <a href="/consulting">Consulting</a>
      <a href="/rss.xml">RSS</a>
    </nav>

    <p class="footer-copy">
      © {year} linuxcore.dev · Built with Astro · Hosted on Cloudflare
    </p>
  </div>
</footer>

<style>
  .lc-footer {
    border-top: 1px solid var(--border);
    background: var(--bg2);
    margin-top: auto;
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    padding: 28px 40px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
  }
  .footer-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .logo-mark-sm {
    width: 22px; height: 22px; border: 1px solid var(--green);
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700; color: var(--green);
  }
  .footer-name { font-family: var(--sans); font-weight: 800; font-size: 14px; color: var(--green); }
  .footer-links { display: flex; gap: 20px; flex-wrap: wrap; }
  .footer-links a { color: var(--text-dim); font-size: 11px; text-decoration: none; letter-spacing: 0.05em; transition: color 0.15s; }
  .footer-links a:hover { color: var(--green); }
  .footer-copy { color: var(--text-dim); font-size: 10px; letter-spacing: 0.05em; }
  @media (max-width: 600px) { .footer-inner { padding: 20px; } }
</style>
