---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="lc-footer">
  <div class="footer-inner">
    <a href="/" class="footer-logo">
      <span class="logo-mark-sm">LC</span>
      <span class="footer-name">linuxcore<span style="color:var(--text-dim)">.dev</span></span>
    </a>

    <nav class="footer-links">
      <a href="/homelab">Homelab</a>
      <a href="/aws">AWS</a>
      <a href="/astro">Astro</a>
      <a href="/scripts">Scripts</a>
      <a href="/shop">Shop</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
      <a href="/#newsletter">Newsletter</a>
      <a href="/rss.xml">RSS</a>
    </nav>

    <div class="footer-legal">
      <a href="/privacy">Privacy & Cookies</a>
      <a href="/gpsr">Product Safety (GPSR)</a>
    </div>
    <p class="footer-copy">
      © {year} linuxcore.dev · Built with Astro · Hosted on Cloudflare
    </p>
  </div>
</footer>

<style>
  .lc-footer {
    border-top: 1px solid var(--border);
    background: var(--bg2);
    margin-top: auto;
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    padding: 28px 40px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
  }
  .footer-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .logo-mark-sm {
    width: 22px; height: 22px; border: 1px solid var(--amber);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: var(--amber);
  }
  .footer-name { font-family: var(--mono); font-weight: 700; font-size: 14px; color: var(--amber); }
  .footer-links { display: flex; gap: 20px; flex-wrap: wrap; }
  .footer-links a { color: var(--text-dim); font-size: 12px; text-decoration: none; letter-spacing: 0.05em; transition: color 0.15s; font-family: var(--mono); }
  .footer-links a:hover { color: var(--amber); }
  .footer-legal { display: flex; gap: 16px; flex-wrap: wrap; }
  .footer-legal a { color: var(--text-dim); font-size: 12px; text-decoration: none; letter-spacing: 0.05em; font-family: var(--mono); transition: color 0.15s; }
  .footer-legal a:hover { color: var(--amber); }
  .footer-copy { color: var(--text-dim); font-size: 12px; letter-spacing: 0.05em; font-family: var(--mono); }
  @media (max-width: 600px) { .footer-inner { padding: 20px; } }
</style>
