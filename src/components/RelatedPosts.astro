---
// src/components/RelatedPosts.astro
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  currentTags: string[];
  section?:    'homelab' | 'astro' | 'aws';
  limit?:      number;
}

const { currentSlug, currentTags, section, limit = 3 } = Astro.props;

const all = await getCollection('blog', ({ data }) => !data.draft);

const scored = all
  .filter(p => p.slug !== currentSlug)
  .map(p => {
    let score = 0;
    if (p.data.section && p.data.section === section) score += 2;
    for (const tag of currentTags) {
      if (p.data.tags?.includes(tag)) score += 1;
    }
    return { post: p, score };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime())
  .slice(0, limit)
  .map(({ post }) => post);

if (scored.length === 0) return;

const sectionHref = (s?: string) =>
  s === 'homelab' ? '/homelab' : s === 'astro' ? '/astro' : s === 'aws' ? '/aws' : '/blog';

const sectionColor = (s?: string) =>
  s === 'astro' ? '#7eb8d4' : s === 'aws' ? '#e8923a' : '#f0a500';

const formatDate = (d: Date) => new Date(d).toLocaleDateString('en-GB', {
  day: '2-digit', month: 'short', year: 'numeric',
});
---

<section class="related-section">
  <div class="related-label">// RELATED</div>
  <h2 class="related-heading">More on this topic</h2>
  <div class="related-grid">
    {scored.map(post => {
      const sec = post.data.section;
      const slug = sec ? `/${sec}/${post.slug}` : `/blog/${post.slug}`;
      const color = sectionColor(sec);
      return (
        <a href={slug} class="rel-card" style={`--rc: ${color}`}>
          <div class="rel-top-line"></div>
          <div class="rel-meta-top">
            {sec && (
              <span class="rel-section-pill" style={`color:${color}; border-color:${color}44; background:${color}11`}>
                {sec}
              </span>
            )}
            {post.data.readingTime && (
              <span class="rel-time">{post.data.readingTime} min</span>
            )}
          </div>
          <h3 class="rel-title">{post.data.title}</h3>
          <p class="rel-desc">{post.data.description}</p>
          <div class="rel-footer">
            <span class="rel-date">{formatDate(post.data.pubDate)}</span>
            <span class="rel-read">read →</span>
          </div>
        </a>
      );
    })}
  </div>
</section>

<style>
  .related-section {
    margin-top: 48px;
    padding-top: 36px;
    border-top: 1px solid var(--border);
  }
  .related-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--amber);
    margin-bottom: 6px;
  }
  .related-heading {
    font-family: var(--display);
    font-size: 18px;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }
  .rel-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 20px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
  }
  .rel-top-line {
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--rc);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.25s;
  }
  .rel-card:hover { border-color: var(--rc); background: var(--bg3); }
  .rel-card:hover .rel-top-line { transform: scaleX(1); }

  .rel-meta-top { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .rel-section-pill {
    font-size: 11px; letter-spacing: 0.1em; font-weight: 700;
    padding: 2px 7px; border: 1px solid; font-family: var(--mono);
  }
  .rel-time { font-size: 11px; color: var(--text-dim); font-family: var(--mono); }

  .rel-title {
    font-family: var(--display);
    font-weight: 600;
    font-size: 16px;
    color: var(--text-bright);
    line-height: 1.35;
    flex: 1;
    letter-spacing: -0.01em;
  }
  .rel-desc {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rel-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }
  .rel-date { font-family: var(--mono); font-size: 11px; color: var(--text-dim); letter-spacing: 0.05em; }
  .rel-read { font-family: var(--mono); font-size: 11px; color: var(--rc); letter-spacing: 0.05em; transition: letter-spacing 0.2s; }
  .rel-card:hover .rel-read { letter-spacing: 0.1em; }
</style>
