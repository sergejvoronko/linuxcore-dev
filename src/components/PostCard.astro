---
// src/components/PostCard.astro
// Usage: <PostCard post={post} featured={true} />

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      pillar: string;
      type: string;
      tags: string[];
      readTime: number;
      featured?: boolean;
    };
  };
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, pillar, type, tags, readTime } = post.data;

// Map pillar → accent color
const pillarColors: Record<string, string> = {
  'Infrastructure':    '#00ff88',
  'Self-Hosted AI':    '#00e5ff',
  'Linux Automation':  '#ffb300',
  'Monitoring':        '#b388ff',
  'Security':          '#ff4466',
  'AWS Hybrid':        '#ffb300',
};

const typeColors: Record<string, string> = {
  PILLAR:  '#00ff88',
  CLUSTER: '#00e5ff',
  UNIQUE:  '#ff6688',
};

const color     = pillarColors[pillar] ?? '#00ff88';
const typeColor = typeColors[type]     ?? '#00ff88';

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: '2-digit', month: 'short', year: 'numeric'
});
---

<a
  href={`/guides/${post.slug}`}
  class:list={['post-card', { featured }]}
  style={`--card-color: ${color};`}
>
  <div class="card-top-line"></div>

  <div class="card-meta-top">
    <span class="tag-pillar" style={`background:${color}22; color:${color}; border-color:${color}44`}>
      {pillar}
    </span>
    <span class="tag-type" style={`background:${typeColor}22; color:${typeColor}; border-color:${typeColor}44`}>
      {type}
    </span>
  </div>

  <h3 class="card-title">{title}</h3>
  {featured && <p class="card-excerpt">{description}</p>}

  <div class="card-footer">
    <span class="card-date">{formattedDate}</span>
    <span class="card-read">{readTime} min read →</span>
  </div>
</a>

<style>
  .post-card {
    display: flex; flex-direction: column; gap: 10px;
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 22px;
    text-decoration: none;
    position: relative; overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
    height: 100%;
  }
  .card-top-line {
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--card-color);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s;
  }
  .post-card:hover { border-color: var(--card-color); background: var(--bg3); }
  .post-card:hover .card-top-line { transform: scaleX(1); }

  .card-meta-top { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag-pillar, .tag-type {
    font-size: 9px; letter-spacing: 0.12em; font-weight: 700;
    padding: 2px 8px; border: 1px solid; font-family: var(--mono);
  }
  .card-title {
    font-family: var(--sans); font-weight: 700;
    color: var(--text-bright); line-height: 1.3;
    font-size: 15px;
    flex: 1;
  }
  .featured .card-title { font-size: 20px; }
  .card-excerpt { color: var(--text-dim); font-size: 12px; line-height: 1.7; }
  .card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 12px; border-top: 1px solid var(--border); }
  .card-date { color: var(--text-dim); font-size: 10px; letter-spacing: 0.05em; }
  .card-read { color: var(--card-color); font-size: 11px; letter-spacing: 0.05em; transition: letter-spacing 0.2s; }
  .post-card:hover .card-read { letter-spacing: 0.1em; }
</style>
