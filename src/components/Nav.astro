---
// src/components/Nav.astro
// Visual style: original LC box logo + mono links
// Structure: new Homelab/Astro dropdowns kept

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const navItems = [
  {
    label: 'Homelab',
    href:  '/homelab',
    dropdown: [
      { label: '/ansible',    href: '/homelab/ansible-homelab' },
      { label: '/docker',     href: '/homelab/docker-compose-homelab-stack' },
      { label: '/grafana',    href: '/homelab/grafana-prometheus-homelab' },
      { label: '/proxmox',    href: '/homelab/proxmox-homelab-setup' },
      { label: '/ollama',     href: '/homelab/ollama-linux-setup' },
      { label: '/n8n',        href: '/homelab/n8n-ollama-automation' },
      { label: '/wireguard',  href: '/homelab/wireguard-tailscale-guide' },
      { label: '/hardening',  href: '/homelab/linux-security-hardening' },
      { label: '/backup',     href: '/homelab/aws-s3-homelab-backup' },
      { label: '/immich',     href: '/homelab/immich-vs-photoprism' },
      { label: '/hardware',   href: '/homelab/best-mini-pc-homelab-2026' },
      { label: '→ all',       href: '/homelab', class: 'see-all' },
    ],
  },
  {
    label: 'Astro',
    href:  '/astro',
    dropdown: [
      { label: '/stack',      href: '/astro/astro-github-cloudflare-stack' },
      { label: '/comments',   href: '/astro/astro-giscus-comments' },
      { label: '/forms',      href: '/astro/astro-cloudflare-contact-form' },
      { label: '/shop',       href: '/astro/astro-printify-stripe-shop' },
      { label: '/seo',        href: '/astro/astro-seo-without-plugins' },
      { label: '/newsletter', href: '/astro/astro-newsletter-mailerLite' },
      { label: '→ all',       href: '/astro', class: 'see-all' },
    ],
  },
  {
    label: 'AWS',
    href:  '/aws',
    dropdown: [
      { label: '/when-to-move',  href: '/aws/when-to-move-homelab-to-aws' },
      { label: '/s3-backups',    href: '/aws/aws-s3-restic-homelab-backups' },
      { label: '/10-euro-stack', href: '/aws/ten-euro-month-aws-stack' },
      { label: '/ollama-gpu',    href: '/aws/ollama-aws-gpu-spot-instance' },
      { label: '/cost-guide',    href: '/aws/aws-cost-guide-spot-reserved-savings' },
      { label: '/terraform',     href: '/aws/terraform-for-homelab-users' },
      { label: '→ all',          href: '/aws', class: 'see-all' },
    ],
  },
  { label: '/scripts', href: '/scripts' },
  { label: '/shop',    href: '/shop' },
  { label: '/about',   href: '/about' },
];
---

<nav class="lc-nav">
  <a href="/" class="nav-logo" aria-label="linuxcore.dev home">
    <div class="logo-mark">LC</div>
    <span class="logo-text">linuxcore<span class="logo-tld">.dev</span></span>
  </a>

  <div class="nav-links" id="nav-links">
    {navItems.map(item => (
      item.dropdown ? (
        <div class="nav-item has-dropdown">
          <button
            class:list={['nav-link', 'nav-trigger', { active: isActive(item.href) }]}
            aria-haspopup="true"
            aria-expanded="false"
          >
            {item.label}
            <svg class="chevron" width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <ul class="dropdown" role="menu">
            {item.dropdown.map(sub => (
              <li role="none">
                <a
                  href={sub.href}
                  class:list={['dropdown-item', sub.class ?? '', { active: isActive(sub.href) && sub.href !== item.href }]}
                  role="menuitem"
                >
                  {sub.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ) : (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
        >
          {item.label}
        </a>
      )
    ))}
    <a href="/#newsletter" class="nav-cta">SUBSCRIBE →</a>
  </div>

  <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">☰</button>

  <div class="nav-progress-track">
    <div id="nav-progress" class="nav-progress-bar"></div>
  </div>
</nav>

<style>
  .lc-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 900;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 40px;
    background: rgba(24,18,10,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    height: var(--nav-height);
  }

  /* ── Logo ─── */
  .nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; flex-shrink: 0; }
  .logo-mark {
    width: 28px; height: 28px; border: 1.5px solid var(--amber);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: var(--amber); font-family: var(--mono);
    box-shadow: 0 0 12px rgba(240,165,0,0.15);
  }
  .logo-text { font-family: var(--mono); font-weight: 700; font-size: 16px; color: var(--amber); letter-spacing: 0.05em; }
  .logo-tld  { color: var(--text-dim); }

  /* ── Links ─── */
  .nav-links { display: flex; gap: 24px; align-items: center; margin-left: auto; }

  .nav-item { position: relative; }

  .nav-link, .nav-trigger {
    color: var(--text-dim); font-size: 11px;
    letter-spacing: 0.1em; transition: color 0.15s;
    text-decoration: none; font-family: var(--mono);
    background: none; border: none; cursor: pointer;
    display: flex; align-items: center; gap: 4px;
    padding: 0;
  }
  .nav-link:hover, .nav-trigger:hover,
  .nav-link.active, .nav-trigger.active { color: var(--amber); }

  .chevron { transition: transform 0.2s; opacity: 0.6; }
  .nav-trigger[aria-expanded="true"] .chevron { transform: rotate(180deg); opacity: 1; }

  /* ── Dropdown ─── */
  .dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 170px;
    background: var(--bg2);
    border: 1px solid var(--border-amber);
    padding: 6px 0;
    list-style: none;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    z-index: 200;
  }
  .has-dropdown:hover .dropdown,
  .nav-trigger[aria-expanded="true"] + .dropdown { display: block; }

  .dropdown-item {
    display: block;
    padding: 6px 16px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.12s, background 0.12s;
  }
  .dropdown-item:hover, .dropdown-item.active {
    color: var(--amber);
    background: var(--amber-glow);
  }
  .dropdown-item.see-all {
    margin-top: 4px;
    padding-top: 8px;
    border-top: 1px solid var(--border);
    color: var(--amber);
    opacity: 0.7;
  }
  .dropdown-item.see-all:hover { opacity: 1; }

  /* ── Subscribe CTA ─── */
  .nav-cta {
    border: 1px solid var(--amber); color: var(--amber) !important;
    padding: 5px 14px; font-size: 11px !important;
    letter-spacing: 0.1em; transition: all 0.15s;
    text-decoration: none; font-family: var(--mono);
    white-space: nowrap;
  }
  .nav-cta:hover { background: var(--amber); color: var(--bg) !important; }

  /* ── Hamburger ─── */
  .nav-toggle { display: none; background: none; border: none; color: var(--amber); font-size: 20px; cursor: pointer; }

  /* ── Reading progress bar ─── */
  .nav-progress-track {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px; background: transparent; overflow: hidden;
  }
  .nav-progress-bar {
    height: 100%; width: 100%;
    background: var(--amber);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.1s linear;
    opacity: 0;
  }

  @media (max-width: 820px) {
    .lc-nav { padding: 14px 20px; }
    .nav-links { display: none; }
    .nav-links.open {
      display: flex; flex-direction: column; gap: 12px;
      position: fixed; top: var(--nav-height); left: 0; right: 0;
      background: var(--bg2); border-bottom: 1px solid var(--border-amber);
      padding: 20px; align-items: flex-start;
    }
    .nav-links.open .has-dropdown { width: 100%; }
    .nav-links.open .dropdown { position: static; transform: none; display: none; margin-top: 8px; min-width: 0; box-shadow: none; }
    .nav-toggle { display: block; margin-left: auto; }
  }
</style>

<script>
  // Dropdown toggle
  const triggers = document.querySelectorAll<HTMLButtonElement>('.nav-trigger');
  triggers.forEach(t => {
    t.addEventListener('click', () => {
      const open = t.getAttribute('aria-expanded') === 'true';
      triggers.forEach(x => x.setAttribute('aria-expanded', 'false'));
      t.setAttribute('aria-expanded', open ? 'false' : 'true');
      // mobile: also toggle the dropdown visibility
      const dd = t.nextElementSibling as HTMLElement;
      if (dd) dd.style.display = open ? '' : 'block';
    });
  });
  document.addEventListener('click', e => {
    if (!(e.target as Element).closest('.has-dropdown'))
      triggers.forEach(t => { t.setAttribute('aria-expanded', 'false'); });
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') triggers.forEach(t => t.setAttribute('aria-expanded', 'false'));
  });

  // Mobile hamburger
  const toggle = document.getElementById('nav-toggle');
  const links  = document.getElementById('nav-links');
  toggle?.addEventListener('click', () => links?.classList.toggle('open'));

  // Reading progress
  const bar     = document.getElementById('nav-progress');
  const article = document.querySelector<HTMLElement>('.prose-content');
  if (bar && article) {
    bar.style.opacity = '1';
    const update = () => {
      const top    = article.offsetTop;
      const height = article.offsetHeight;
      const pct    = Math.min(100, Math.max(0, ((window.scrollY - top) / height) * 100));
      bar.style.transform = `scaleX(${pct / 100})`;
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
