---
// src/components/TableOfContents.astro
// Usage: <TableOfContents headings={headings} />
// Pass in: const { headings } = Astro.props from a content collection render()

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Only show H2 and H3 — H1 is the title, H4+ is too granular
const toc = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{toc.length > 1 && (
  <nav class="toc" id="toc" aria-label="Table of contents">
    <div class="toc-header">
      <span class="toc-label">ON THIS PAGE</span>
    </div>
    <ol class="toc-list">
      {toc.map(heading => (
        <li class:list={['toc-item', { 'toc-h3': heading.depth === 3 }]}>
          <a
            href={`#${heading.slug}`}
            class="toc-link"
            data-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
    <div class="toc-progress">
      <div class="toc-progress-bar" id="toc-progress"></div>
    </div>
  </nav>
)}

<style>
  .toc {
    position: sticky;
    top: 80px;                        /* clears the fixed nav */
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding: 0;
    scrollbar-width: thin;
    scrollbar-color: #1a2e1a transparent;
  }
  .toc::-webkit-scrollbar       { width: 3px; }
  .toc::-webkit-scrollbar-thumb { background: #1a2e1a; }

  .toc-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .toc-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--amber);
    font-family: var(--mono);
    font-weight: 700;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .toc-item { display: block; }

  .toc-link {
    display: block;
    font-size: 12px;
    line-height: 1.5;
    color: var(--text-dim);
    text-decoration: none;
    padding: 4px 10px 4px 10px;
    border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    font-family: var(--sans);
  }
  .toc-link:hover {
    color: var(--text);
    border-left-color: var(--border-mid);
  }
  .toc-link.active {
    color: var(--amber);
    border-left-color: var(--amber);
    background: var(--amber-glow);
  }

  .toc-h3 .toc-link {
    padding-left: 22px;
    font-size: 11px;
  }

  .toc-progress {
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--border);
    height: 3px;
    background: var(--bg3);
    border-radius: 2px;
    overflow: hidden;
  }
  .toc-progress-bar {
    height: 100%;
    width: 0%;
    background: var(--amber);
    border-radius: 2px;
    transition: width 0.1s linear;
  }
</style>

<script>
  // Highlight active heading as user scrolls
  const links    = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const progress = document.getElementById('toc-progress');

  if (links.length > 0) {
    // Build a map of slug → link element
    const linkMap = new Map<string, HTMLAnchorElement>();
    links.forEach(link => {
      const slug = link.dataset.slug;
      if (slug) linkMap.set(slug, link);
    });

    // Get all headings in the article
    const headingEls = Array.from(
      document.querySelectorAll<HTMLHeadingElement>('.prose-content h2, .prose-content h3')
    );

    const tocEl = document.getElementById('toc');

    const setActive = (slug: string) => {
      links.forEach(l => l.classList.remove('active'));
      const activeLink = linkMap.get(slug);
      if (activeLink) {
        activeLink.classList.add('active');
        // Scroll only the TOC container, not the page
        if (tocEl) {
          const linkTop    = activeLink.offsetTop;
          const linkBottom = linkTop + activeLink.offsetHeight;
          const tocTop     = tocEl.scrollTop;
          const tocBottom  = tocTop + tocEl.clientHeight;
          if (linkTop < tocTop || linkBottom > tocBottom) {
            tocEl.scrollTo({ top: linkTop - tocEl.clientHeight / 2, behavior: 'smooth' });
          }
        }
      }
    };

    // Intersection Observer — fires when headings enter/leave viewport
    const observer = new IntersectionObserver(
      entries => {
        // Find the topmost visible heading
        const visible = entries
          .filter(e => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      {
        rootMargin: '-80px 0px -60% 0px',  // triggers when heading is near top of viewport
        threshold: 0,
      }
    );

    headingEls.forEach(el => observer.observe(el));

    // Reading progress bar
    const updateProgress = () => {
      const article   = document.querySelector<HTMLElement>('.prose-content');
      if (!article || !progress) return;

      const articleTop    = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const scrolled      = window.scrollY - articleTop;
      const pct           = Math.min(100, Math.max(0, (scrolled / articleHeight) * 100));
      progress.style.width = pct + '%';
    };

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // Smooth scroll on TOC link click
    links.forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        const slug = link.dataset.slug;
        const target = slug ? document.getElementById(slug) : null;
        if (target) {
          const offset = 90; // nav height + breathing room
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });
  }
</script>
