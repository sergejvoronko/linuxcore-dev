---
// src/components/ArticleCard.astro
interface Props {
  title:       string;
  description: string;
  href:        string;
  pubDate:     Date;
  tags?:       string[];
  featured?:   boolean;
  section?:    string;
}

const { title, description, href, pubDate, tags = [], featured = false, section } = Astro.props;

const color = section === 'astro' ? '#7eb8d4' : '#f0a500';

const dateStr = pubDate.toLocaleDateString('en-GB', {
  day: '2-digit', month: 'short', year: 'numeric',
});
---

<a href={href} class:list={['post-card', { featured }]} style={`--card-color: ${color}`}>
  <div class="card-top-line"></div>

  <div class="card-meta-top">
    {tags.slice(0, 2).map(t => (
      <span class="tag-pill" style={`background:${color}22; color:${color}; border-color:${color}44`}>
        {t}
      </span>
    ))}
  </div>

  <h3 class="card-title">{title}</h3>
  {description && <p class="card-excerpt">{description}</p>}

  <div class="card-footer">
    <span class="card-date">{dateStr}</span>
    <span class="card-read">read article →</span>
  </div>
</a>

<style>
  .post-card {
    display: flex; flex-direction: column; gap: 12px;
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 28px;
    text-decoration: none;
    position: relative; overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
    height: 100%;
  }
  .card-top-line {
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: var(--card-color);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s;
  }
  .post-card:hover { border-color: var(--card-color); background: var(--bg3); }
  .post-card:hover .card-top-line { transform: scaleX(1); }
  .post-card.featured { border-color: var(--border-amber); }

  .card-meta-top { display: flex; gap: 8px; flex-wrap: wrap; }
  .tag-pill {
    font-size: 12px; letter-spacing: 0.1em; font-weight: 700;
    padding: 2px 8px; border: 1px solid; font-family: var(--mono);
  }

  .card-title {
    font-family: var(--display); font-weight: 600;
    color: var(--text-bright); line-height: 1.3;
    font-size: 19px; flex: 1; letter-spacing: -0.01em;
  }
  .featured .card-title { font-size: 22px; }

  .card-excerpt { color: var(--text-mid); font-size: 15px; line-height: 1.7; font-family: var(--sans); }

  .card-footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: auto; padding-top: 14px; border-top: 1px solid var(--border);
  }
  .card-date { color: var(--text-mid); font-size: 12px; letter-spacing: 0.05em; font-family: var(--mono); }
  .card-read { color: var(--card-color); font-size: 12px; letter-spacing: 0.05em; transition: letter-spacing 0.2s; font-family: var(--mono); }
  .post-card:hover .card-read { letter-spacing: 0.1em; }
</style>
