---
// src/components/NewsletterBanner.astro
// Sticky bottom banner — shown once per session, hides on dismiss or subscribe
---

<div class="nl-banner" id="nl-banner" role="complementary" aria-label="Newsletter signup">
  <div class="nl-banner-inner">
    <div class="nl-banner-text">
      <span class="nl-banner-label">// NEWSLETTER</span>
      <span class="nl-banner-msg">New guides and scripts when they're ready — no spam.</span>
    </div>
    <form class="nl-banner-form" id="nl-banner-form" novalidate>
      <label for="nl-banner-email" class="sr-only">Email address</label>
      <input
        type="email"
        id="nl-banner-email"
        name="email"
        placeholder="your@email.com"
        autocomplete="email"
        required
        class="nl-banner-input"
      />
      <button type="submit" class="nl-banner-btn" id="nl-banner-btn">SUBSCRIBE →</button>
    </form>
    <div id="nl-banner-status" class="nl-banner-status" role="alert" aria-live="polite"></div>
  </div>
  <button class="nl-banner-close" id="nl-banner-close" aria-label="Dismiss newsletter banner">✕</button>
</div>

<style>
  .nl-banner {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 800;
    background: var(--bg2);
    border-top: 1px solid var(--border-amber);
    padding: 12px 24px;
    display: none;
    align-items: center;
    gap: 20px;
    box-shadow: 0 -4px 24px rgba(0,0,0,0.4);
  }
  .nl-banner.visible { display: flex; }
  .nl-banner-inner {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .nl-banner-text { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .nl-banner-label {
    font-family: var(--mono); font-size: 11px;
    letter-spacing: 0.14em; color: var(--amber);
    white-space: nowrap;
  }
  .nl-banner-msg {
    font-family: var(--mono); font-size: 12px;
    color: var(--text-dim); white-space: nowrap;
  }
  .nl-banner-form { display: flex; gap: 8px; flex-shrink: 0; }
  .nl-banner-input {
    width: 220px;
    padding: 7px 12px;
    background: var(--bg); border: 1px solid var(--border-mid);
    color: var(--text); font-family: var(--mono); font-size: 12px;
    outline: none; transition: border-color 0.15s;
  }
  .nl-banner-input:focus { border-color: var(--amber); }
  .nl-banner-input::placeholder { color: var(--text-dim); }
  .nl-banner-btn {
    background: var(--amber); color: var(--bg);
    border: none; padding: 7px 16px;
    font-family: var(--mono); font-size: 11px;
    font-weight: 700; letter-spacing: 0.08em;
    cursor: pointer; white-space: nowrap;
    transition: background 0.15s;
  }
  .nl-banner-btn:hover { background: #ffc94d; }
  .nl-banner-btn:disabled { opacity: 0.6; cursor: default; }
  .nl-banner-status {
    font-family: var(--mono); font-size: 11px;
    display: none; padding: 4px 10px;
  }
  .nl-banner-status.success { display: block; color: var(--green, #4eca8b); }
  .nl-banner-status.error   { display: block; color: #ff6b6b; }
  .nl-banner-close {
    background: none; border: none;
    color: var(--text-dim); font-size: 14px;
    cursor: pointer; padding: 4px 8px;
    transition: color 0.15s; flex-shrink: 0;
  }
  .nl-banner-close:hover { color: var(--amber); }

  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; }

  @media (max-width: 700px) {
    .nl-banner { padding: 12px 16px; }
    .nl-banner-msg { display: none; }
    .nl-banner-input { width: 160px; }
  }
</style>

<script>
  const STORAGE_KEY = 'lc_nl_banner_dismissed';

  const banner  = document.getElementById('nl-banner');
  const closeBtn = document.getElementById('nl-banner-close');
  const form    = document.getElementById('nl-banner-form')    as HTMLFormElement;
  const input   = document.getElementById('nl-banner-email')   as HTMLInputElement;
  const btn     = document.getElementById('nl-banner-btn')     as HTMLButtonElement;
  const status  = document.getElementById('nl-banner-status')  as HTMLDivElement;

  function dismiss() {
    banner?.classList.remove('visible');
    sessionStorage.setItem(STORAGE_KEY, '1');
  }

  if (!sessionStorage.getItem(STORAGE_KEY)) {
    // Delay so it doesn't flash immediately on page load
    setTimeout(() => banner?.classList.add('visible'), 4000);
  }

  closeBtn?.addEventListener('click', dismiss);

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = input.value.trim();
    if (!email) return;

    btn.disabled = true;
    btn.textContent = '…';
    status.className = 'nl-banner-status';
    status.textContent = '';

    try {
      const res  = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json() as { ok?: boolean; note?: string; error?: string };

      if (data.ok) {
        status.className   = 'nl-banner-status success';
        status.textContent = data.note === 'already_subscribed' ? '✓ Already subscribed!' : '✓ Subscribed!';
        form.reset();
        setTimeout(dismiss, 2500);
      } else {
        throw new Error(data.error ?? 'Error');
      }
    } catch (err: any) {
      status.className   = 'nl-banner-status error';
      status.textContent = `✕ ${err.message}`;
    } finally {
      btn.disabled = false;
      btn.textContent = 'SUBSCRIBE →';
    }
  });
</script>
