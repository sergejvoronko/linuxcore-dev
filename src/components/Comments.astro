---
// src/components/Comments.astro
// GitHub Discussions-based comments via Giscus.
//
// SETUP (5 min, one-time):
//  1. Enable Discussions on your GitHub repo (Settings → Features)
//  2. Install Giscus app: github.com/apps/giscus → select your repo
//  3. Go to giscus.app, paste your repo URL
//  4. Replace the three placeholder values below with what giscus.app gives you
---

<section class="comments-section">
  <h2 class="comments-heading">
    <span class="bracket">[</span>discussion<span class="bracket">]</span>
  </h2>
  <p class="comments-note">
    Comments are powered by <a href="https://giscus.app" target="_blank" rel="noopener">Giscus</a>
    — backed by GitHub Discussions. Sign in with GitHub to join the conversation.
  </p>

  <div class="giscus-wrap" id="giscus-wrap"></div>
</section>

<script>
  // Lazy-load Giscus only when the comments section nears the viewport.
  // Avoids the third-party client.js request + iframe on initial page load.
  const mount = document.getElementById('giscus-wrap');
  if (mount) {
    const load = () => {
      const s = document.createElement('script');
      s.src = 'https://giscus.app/client.js';
      s.async = true;
      s.crossOrigin = 'anonymous';
      Object.entries({
        'data-repo': 'sergejvoronko/linuxcore-dev',
        'data-repo-id': 'R_kgDORwto8A',
        'data-category': 'Comments',
        'data-category-id': 'DIC_kwDORwto8M4C6SLq',
        'data-mapping': 'pathname',
        'data-strict': '0',
        'data-reactions-enabled': '1',
        'data-emit-metadata': '0',
        'data-input-position': 'top',
        'data-theme': 'https://linuxcore-dev.airbrushden.workers.dev/giscus-amber.css',
        'data-lang': 'en',
      }).forEach(([k, v]) => s.setAttribute(k, v));
      mount.appendChild(s);
    };
    const io = new IntersectionObserver((entries, obs) => {
      if (entries.some(e => e.isIntersecting)) { load(); obs.disconnect(); }
    }, { rootMargin: '600px' });
    io.observe(mount);
  }
</script>

<style>
  .comments-section {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .comments-heading {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }
  .bracket { opacity: 0.4; }

  .comments-note {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }
  .comments-note a { color: var(--amber); }

  .giscus-wrap {
    min-height: 120px;
    width: 100%;
  }
  .giscus-wrap :global(.giscus),
  .giscus-wrap :global(.giscus-frame) {
    width: 100% !important;
  }
</style>
