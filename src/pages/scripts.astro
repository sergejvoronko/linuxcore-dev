---
// src/pages/scripts.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const freeScripts = [
  {
    name:        'server-hardening.sh',
    description: 'Baseline Linux server hardening: SSH config, firewall rules, fail2ban, unattended upgrades, and sysctl tweaks. Tested on Ubuntu 22.04/24.04.',
    tags:        ['bash', 'security', 'ubuntu'],
    githubSlug:  'server-hardening',
  },
  {
    name:        'docker-install.sh',
    description: 'Idempotent Docker CE + Compose plugin installer for Debian/Ubuntu. Adds the official repo, verifies GPG key, and starts the daemon.',
    tags:        ['bash', 'docker', 'ubuntu'],
    githubSlug:  'docker-install',
  },
  {
    name:        'restic-backup.sh',
    description: 'Restic backup to S3-compatible storage (AWS, Backblaze B2, Hetzner). Handles init, backup, forget/prune, and health-check notification.',
    tags:        ['bash', 'backup', 'restic', 'aws'],
    githubSlug:  'restic-backup',
  },
  {
    name:        'prometheus-node-exporter.sh',
    description: 'Installs and configures Node Exporter as a systemd service. Ready to scrape from any Prometheus instance.',
    tags:        ['bash', 'monitoring', 'prometheus'],
    githubSlug:  'prometheus-node-exporter',
  },
  {
    name:        'ollama-install.sh',
    description: 'Installs Ollama with automatic GPU detection (NVIDIA/AMD/CPU fallback). Pulls a default model and sets up as a systemd service.',
    tags:        ['bash', 'ai', 'ollama', 'gpu'],
    githubSlug:  'ollama-install',
  },
  {
    name:        'tailscale-setup.sh',
    description: 'Installs Tailscale, authenticates, enables exit node and subnet routing, and configures auto-update.',
    tags:        ['bash', 'vpn', 'tailscale', 'networking'],
    githubSlug:  'tailscale-setup',
  },
];
---

<BaseLayout
  title="Scripts"
  description="Free production-ready Bash scripts for Linux hardening, Docker, backups, monitoring, and more. Plus the Ansible Homelab Bundle for full automation."
>
  <main class="scripts-page">

    <!-- Hero -->
    <section class="page-hero">
      <div class="hero-label"><span class="tb">[</span>scripts<span class="tb">]</span></div>
      <h1 class="hero-title">Scripts &amp; Tools</h1>
      <p class="hero-lead">
        Production-ready Bash scripts for Linux infrastructure. Free to use, free to modify.
        Everything is on GitHub — no email required.
      </p>
    </section>

    <!-- Free scripts -->
    <section class="scripts-section">
      <h2 class="section-label"><span class="sl-pre">$</span> Free Scripts</h2>
      <p class="section-note">
        All scripts are in the
        <a href="https://github.com/linuxcore-dev/linuxcore-scripts" target="_blank" rel="noopener">linuxcore-scripts</a>
        GitHub repo. Click any script to view or download.
      </p>
      <div class="scripts-grid">
        {freeScripts.map(s => (
          <div class="script-card">
            <div class="script-header">
              <code class="script-name">{s.name}</code>
              <a
                href={`https://github.com/linuxcore-dev/linuxcore-scripts/blob/main/${s.githubSlug}.sh`}
                target="_blank"
                rel="noopener"
                class="script-gh-link"
                aria-label={`View ${s.name} on GitHub`}
              >
                ↗ GitHub
              </a>
            </div>
            <p class="script-desc">{s.description}</p>
            <div class="script-tags">
              {s.tags.map(t => <span class="chip">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Ansible bundle -->
    <section class="bundle-section" id="ansible-bundle">
      <div class="bundle-card">
        <div class="bundle-badge">Premium</div>
        <div class="bundle-body">
          <p class="bundle-eyebrow"><span class="tb">[</span>ansible<span class="tb">]</span></p>
          <h2 class="bundle-title">Ansible Homelab Bundle</h2>
          <p class="bundle-desc">
            25 production-ready Ansible files that turn a fresh Linux machine into a fully
            configured homelab node — hardened, monitored, and ready to run AI workloads.
          </p>

          <div class="bundle-includes">
            <div class="includes-col">
              <div class="includes-label">5 Roles</div>
              <ul class="includes-list">
                <li>Base server hardening</li>
                <li>Docker CE + Compose</li>
                <li>SSH &amp; kernel security + CrowdSec</li>
                <li>Prometheus + Grafana monitoring</li>
                <li>Ollama + Open WebUI (auto GPU)</li>
              </ul>
            </div>
            <div class="includes-col">
              <div class="includes-label">5 Playbooks</div>
              <ul class="includes-list">
                <li>Fleet package updates</li>
                <li>Restic S3 backup</li>
                <li>SSH hardening</li>
                <li>Ollama model pulling</li>
                <li>Health check summary</li>
              </ul>
            </div>
            <div class="includes-col">
              <div class="includes-label">Also included</div>
              <ul class="includes-list">
                <li>Inventory templates</li>
                <li>Group vars structure</li>
                <li>Vault secrets example</li>
                <li>Full README + usage docs</li>
                <li>Lifetime updates</li>
              </ul>
            </div>
          </div>

          <div class="bundle-footer">
            <div class="bundle-price">
              <span class="price-amount">€29</span>
              <span class="price-note">one-time · instant download</span>
            </div>
            <a
              href="/go/ansible-bundle"
              class="btn-primary"
              target="_blank"
              rel="noopener"
            >
              Get the Bundle →
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>

<style>
  .scripts-page { max-width: var(--wide-w); margin: 0 auto; padding: 3rem 1.5rem 5rem; }

  /* Hero */
  .page-hero { margin-bottom: 3.5rem; }
  .hero-label { font-family: var(--font-mono); font-size: 0.78rem; color: var(--amber); margin-bottom: 0.75rem; }
  .tb { opacity: 0.35; }
  .hero-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: var(--text-bright); margin-bottom: 0.75rem; line-height: 1.1; }
  .hero-lead { font-size: 1.05rem; color: var(--text-mid); max-width: 52ch; line-height: 1.7; }

  /* Free scripts */
  .scripts-section { margin-bottom: 4rem; }
  .section-label { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.6rem; }
  .sl-pre { color: var(--amber); }
  .section-note { font-size: 0.87rem; color: var(--text-dim); margin-bottom: 1.75rem; }
  .section-note a { color: var(--amber); }

  .scripts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }

  .script-card {
    padding: 1.4rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s;
  }
  .script-card:hover { border-color: var(--amber-border); }

  .script-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; gap: 0.5rem; }
  .script-name { font-family: var(--font-mono); font-size: 0.82rem; color: var(--amber); background: var(--bg-code); padding: 0.25em 0.6em; border-radius: 3px; }
  .script-gh-link { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-dim); text-decoration: none; white-space: nowrap; transition: color 0.15s; }
  .script-gh-link:hover { color: var(--amber); }
  .script-desc { font-size: 0.87rem; color: var(--text-mid); line-height: 1.6; margin-bottom: 0.85rem; }
  .script-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  /* Bundle */
  .bundle-section { margin-bottom: 2rem; }

  .bundle-card {
    position: relative;
    background: var(--bg2);
    border: 1px solid var(--amber-border);
    border-radius: 10px;
    overflow: hidden;
  }

  .bundle-badge {
    position: absolute;
    top: 1.25rem; right: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: #18120a;
    background: var(--amber);
    padding: 0.2em 0.7em;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .bundle-body { padding: 2.5rem; }

  .bundle-eyebrow { font-family: var(--font-mono); font-size: 0.72rem; color: var(--amber); margin-bottom: 0.5rem; }
  .bundle-title { font-family: var(--font-display); font-size: 1.8rem; font-weight: 700; color: var(--text-bright); margin-bottom: 0.75rem; }
  .bundle-desc { font-size: 0.97rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 2rem; max-width: 58ch; }

  .bundle-includes { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 2rem; margin-bottom: 2.5rem; }

  .includes-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--amber);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }

  .includes-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.35rem; }
  .includes-list li { font-size: 0.87rem; color: var(--text-mid); padding-left: 1em; position: relative; }
  .includes-list li::before { content: '→'; position: absolute; left: 0; color: var(--amber); opacity: 0.6; font-family: var(--font-mono); font-size: 0.75rem; }

  .bundle-footer { display: flex; align-items: center; gap: 2rem; padding-top: 1.75rem; border-top: 1px solid var(--border); flex-wrap: wrap; }

  .bundle-price { display: flex; flex-direction: column; }
  .price-amount { font-family: var(--font-mono); font-size: 2rem; color: var(--amber); line-height: 1; }
  .price-note { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-dim); margin-top: 0.2rem; }
</style>
