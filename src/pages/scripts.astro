---
// src/pages/scripts.astro
// Free scripts + paid Ansible bundle product page

import BaseLayout from '../layouts/BaseLayout.astro';

const freeScripts = [
  {
    title: 'Docker Health Check',
    desc: 'Scans all running containers, reports unhealthy ones, and sends a Telegram alert. Drop it in cron or a systemd timer.',
    file: 'docker-health-check.sh',
    tags: ['bash', 'docker', 'monitoring'],
    lines: 48,
    color: '#00e5ff',
  },
  {
    title: 'Restic Backup Wrapper',
    desc: 'Full restic backup script with logging, retention policy, integrity check, and Telegram notification on failure.',
    file: 'restic-backup.sh',
    tags: ['bash', 'backup', 'restic', 'aws'],
    lines: 95,
    color: '#ffb300',
  },
  {
    title: 'Proxmox Container Provisioner',
    desc: 'One-liner CLI to spin up a new LXC container with sane defaults — hostname, RAM, IP, SSH key — no GUI needed.',
    file: 'pct-create.sh',
    tags: ['bash', 'proxmox', 'lxc'],
    lines: 62,
    color: '#00ff88',
  },
  {
    title: 'UFW Homelab Ruleset',
    desc: 'Idempotent UFW setup script. Applies the full homelab firewall baseline from the security hardening guide.',
    file: 'ufw-homelab.sh',
    tags: ['bash', 'security', 'ufw'],
    lines: 55,
    color: '#ff4466',
  },
  {
    title: 'Ollama Model Manager',
    desc: 'Pull, list, benchmark, and prune Ollama models. Includes a size report so you know what is eating your disk.',
    file: 'ollama-manager.sh',
    tags: ['bash', 'ollama', 'ai'],
    lines: 71,
    color: '#00e5ff',
  },
  {
    title: 'Docker Volume Backup',
    desc: 'Backs up all named Docker volumes to a tar archive. Supports exclusions, compression, and rotation.',
    file: 'docker-volume-backup.sh',
    tags: ['bash', 'docker', 'backup'],
    lines: 83,
    color: '#b388ff',
  },
];

const bundleFeatures = [
  { icon: '🐧', title: '5 Ansible roles', desc: 'base, docker, monitoring, security, ollama — production-tested, idempotent' },
  { icon: '📋', title: 'Full inventory template', desc: 'Multi-group inventory with variables for homelab, NAS, VPS, and monitoring nodes' },
  { icon: '🔐', title: 'Vault secrets template', desc: 'Pre-structured group_vars/secrets.yml with every common secret placeholder' },
  { icon: '🚀', title: 'One-command deploy', desc: 'Single site.yml that provisions a fresh Ubuntu box to full homelab stack in 8 minutes' },
  { icon: '📦', title: '12 ready-made playbooks', desc: 'Update all nodes, deploy stack, rotate secrets, backup configs, harden SSH' },
  { icon: '📖', title: 'Role README files', desc: 'Each role documented with variables, dependencies, and example usage' },
];
---

<BaseLayout
  title="Scripts & Ansible Playbooks"
  description="Free bash scripts and a complete Ansible homelab automation bundle — provision your entire Linux stack from one command."
>

  <!-- ── HERO ──────────────────────────────────────────────── -->
  <section class="scripts-hero">
    <img src="/images/section-scripts.webp" alt="" class="hero-photo" width="1280" height="720" aria-hidden="true" />
    <div class="hero-grid"></div>
    <div class="hero-inner">
      <div class="hero-label">
        <span class="live-dot"></span>
        SCRIPTS & AUTOMATION
      </div>
      <h1 class="hero-title">
        Stop running commands<br>
        <span class="accent">from memory.</span>
      </h1>
      <p class="hero-sub">
        Free bash scripts for everyday homelab tasks. Plus a complete
        Ansible bundle that provisions your entire stack from one command.
      </p>
    </div>
  </section>

  <!-- ── FREE SCRIPTS ───────────────────────────────────────── -->
  <section class="section">
    <div class="section-inner">
      <div class="section-label">FREE SCRIPTS</div>
      <h2 class="section-title">Download and use. <span>No sign-up.</span></h2>
      <p class="section-desc">
        Every script is self-contained, commented, and tested on Ubuntu 22.04+
        and Debian 12. Copy the raw file or clone the
        <a href="https://github.com/linuxcore-dev/homelab-scripts" target="_blank" rel="noopener">
          GitHub repo
        </a>.
      </p>

      <div class="scripts-grid">
        {freeScripts.map(script => (
          <div class="script-card" style={`--sc:${script.color}`}>
            <div class="script-header">
              <code class="script-file">{script.file}</code>
              <span class="script-lines">{script.lines} lines</span>
            </div>
            <h3 class="script-title">{script.title}</h3>
            <p class="script-desc">{script.desc}</p>
            <div class="script-footer">
              <div class="script-tags">
                {script.tags.map(tag => (
                  <span class="tag">#{tag}</span>
                ))}
              </div>
              <a
                href={`https://raw.githubusercontent.com/linuxcore-dev/homelab-scripts/main/${script.file}`}
                target="_blank"
                rel="noopener"
                class="script-dl"
              >
                ↓ RAW
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="repo-cta">
        <p>All scripts live in the public GitHub repo — star it to get notified when new ones are added.</p>
        <a
          href="https://github.com/linuxcore-dev/homelab-scripts"
          target="_blank"
          rel="noopener"
          class="btn-secondary"
        >
          ⭐ View GitHub Repo →
        </a>
      </div>
    </div>
  </section>

  <!-- ── ANSIBLE BUNDLE ─────────────────────────────────────── -->
  <section class="section bundle-section" id="ansible-bundle">
    <div class="section-inner">

      <div class="bundle-badge">DIGITAL PRODUCT</div>

      <div class="bundle-layout">

        <!-- Left — pitch -->
        <div class="bundle-pitch">
          <div class="section-label">ANSIBLE HOMELAB BUNDLE</div>
          <h2 class="bundle-title">
            Provision your entire homelab<br>
            <span>in 8 minutes.</span>
          </h2>

          <p class="bundle-desc">
            Everything you need to go from a fresh Ubuntu install to a fully
            running homelab stack — Ollama, Docker, Prometheus, Grafana,
            security hardening — with one command.
          </p>
          <p class="bundle-desc">
            Built from the same Ansible patterns in the
            <a href="/guides/ansible-homelab-guide">Ansible guide</a>,
            but production-ready: variables extracted, secrets vaulted,
            handlers wired up, and tested on real hardware.
          </p>

          <div class="bundle-features">
            {bundleFeatures.map(f => (
              <div class="bundle-feature">
                <span class="feature-icon">{f.icon}</span>
                <div>
                  <div class="feature-title">{f.title}</div>
                  <div class="feature-desc">{f.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right — pricing card -->
        <div class="bundle-card">
          <div class="bundle-price-label">ONE-TIME PURCHASE</div>
          <div class="bundle-price">€29</div>
          <div class="bundle-price-sub">Instant download · Lifetime updates</div>

          <ul class="bundle-list">
            <li>✓ 5 production Ansible roles</li>
            <li>✓ 12 ready-made playbooks</li>
            <li>✓ Inventory + vars templates</li>
            <li>✓ Vault secrets structure</li>
            <li>✓ Role documentation</li>
            <li>✓ Free updates forever</li>
          </ul>

          <!-- Gumroad buy button — replace PRODUCT_ID -->
          <a
            href="https://linuxcore-dev.gumroad.com/l/ansible-homelab-bundle"
            target="_blank"
            rel="noopener"
            class="buy-btn"
            data-gumroad-overlay="true"
          >
            BUY NOW →
          </a>

          <p class="bundle-guarantee">
            30-day money-back guarantee. If it doesn't work on your setup,
            full refund — no questions.
          </p>

          <div class="bundle-meta">
            <span>📦 ZIP download</span>
            <span>~180KB</span>
            <span>MIT licence</span>
          </div>
        </div>

      </div>

      <!-- Preview of what's inside -->
      <div class="bundle-preview">
        <div class="preview-label">WHAT'S INSIDE</div>
        <pre class="file-tree">ansible-homelab-bundle/
├── site.yml                    ← run this to deploy everything
├── inventory.ini               ← add your machines here
├── group_vars/
│   ├── all.yml                 ← shared variables
│   └── secrets.yml.example     ← vault template
├── roles/
│   ├── base/                   ← system hardening, UFW, fail2ban
│   ├── docker/                 ← Docker CE + Compose plugin
│   ├── monitoring/             ← Prometheus + Grafana + Node Exporter
│   ├── security/               ← SSH hardening, CrowdSec, sysctl
│   └── ollama/                 ← Ollama + Open WebUI + GPU detection
└── playbooks/
    ├── update-all.yml          ← apt upgrade across all nodes
    ├── deploy-stack.yml        ← full stack deploy
    ├── backup-configs.yml      ← back up all configs to S3
    ├── rotate-secrets.yml      ← regenerate credentials
    ├── harden-ssh.yml          ← SSH hardening only
    └── ... 7 more playbooks</pre>
      </div>

    </div>
  </section>

  <!-- ── NEWSLETTER CTA ─────────────────────────────────────── -->
  <section class="section">
    <div class="section-inner">
      <div class="nl-strip">
        <div>
          <div class="nl-title">More scripts on the way.</div>
          <div class="nl-sub">
            Subscribe — get notified when new tools, scripts, and configs are published.
          </div>
        </div>
        <a href="/newsletter" class="btn-primary">SUBSCRIBE →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<!-- Gumroad overlay script -->
<script src="https://gumroad.com/js/gumroad.js"></script>

<style>
  /* Hero */
  .scripts-hero {
    min-height: 40vh; display: flex; align-items: center;
    padding: 80px 40px 48px; position: relative; overflow: hidden;
  }
  .hero-photo {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    opacity: 0.18;
  }
  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(0,255,136,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,136,.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
  }
  .hero-inner { max-width: 600px; z-index: 1; }
  .hero-label { font-size: 12px; letter-spacing: .16em; color: var(--green); display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
  .live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:.5} 50%{opacity:1} }
  .hero-title { font-family: var(--sans); font-weight: 800; font-size: clamp(30px, 5vw, 56px); line-height: 1.05; color: var(--text-bright); margin-bottom: 12px; }
  .accent { color: var(--green); display: block; }
  .hero-sub { font-size: 14px; color: var(--text-dim); line-height: 1.8; max-width: 480px; }

  /* Sections */
  .section { padding: 64px 40px; }
  .section:nth-child(even) { background: var(--bg2); }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-label { font-size: 12px; letter-spacing: .16em; color: var(--green); margin-bottom: 8px; }
  .section-label::before { content: '// '; color: var(--text-dim); }
  .section-title { font-family: var(--sans); font-weight: 800; font-size: clamp(22px, 3vw, 36px); color: var(--text-bright); line-height: 1.15; margin-bottom: 10px; }
  .section-title span { color: var(--green); }
  .section-desc { color: var(--text-dim); font-size: 13px; line-height: 1.7; margin-bottom: 32px; }
  .section-desc a { color: var(--green); }

  /* Scripts grid */
  .scripts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 16px; margin-bottom: 32px; }
  .script-card {
    border: 1px solid var(--border); background: var(--bg2); padding: 20px;
    transition: border-color .15s, background .15s;
  }
  .script-card:hover { border-color: var(--sc); background: var(--bg3); }
  .script-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .script-file { font-size: 12px; color: var(--sc); font-family: var(--mono); }
  .script-lines { font-size: 12px; color: var(--text-dim); font-family: var(--mono); }
  .script-title { font-family: var(--sans); font-weight: 700; font-size: 14px; color: var(--text-bright); margin-bottom: 8px; }
  .script-desc { font-size: 12px; color: var(--text-dim); line-height: 1.65; margin-bottom: 14px; }
  .script-footer { display: flex; justify-content: space-between; align-items: center; }
  .script-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .tag { font-size: 12px; color: var(--text-dim); font-family: var(--mono); }
  .script-dl { font-size: 12px; font-family: var(--mono); color: var(--sc); text-decoration: none; letter-spacing: .05em; transition: opacity .15s; }
  .script-dl:hover { opacity: .7; }

  .repo-cta { border: 1px solid var(--border); padding: 20px 24px; display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
  .repo-cta p { color: var(--text-dim); font-size: 13px; }

  /* Buttons */
  .btn-primary { background: var(--green); color: var(--bg); border: none; padding: 11px 24px; font-family: var(--mono); font-size: 12px; font-weight: 700; letter-spacing: .08em; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: background .15s; cursor: pointer; }
  .btn-primary:hover { background: #00ffaa; color: var(--bg); }
  .btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border); padding: 11px 24px; font-family: var(--mono); font-size: 12px; letter-spacing: .08em; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all .15s; }
  .btn-secondary:hover { border-color: var(--green); color: var(--green); }

  /* Bundle */
  .bundle-section { background: var(--bg2); }
  .bundle-badge { display: inline-block; background: rgba(0,255,136,.1); border: 1px solid rgba(0,255,136,.3); color: var(--green); font-size: 12px; letter-spacing: .16em; padding: 3px 12px; font-family: var(--mono); margin-bottom: 20px; }
  .bundle-layout { display: grid; grid-template-columns: 1fr 320px; gap: 56px; align-items: start; margin-bottom: 48px; }
  @media(max-width:900px){ .bundle-layout { grid-template-columns: 1fr; gap: 32px; } }

  .bundle-title { font-family: var(--sans); font-weight: 800; font-size: clamp(24px, 3.5vw, 40px); color: var(--text-bright); line-height: 1.1; margin-bottom: 16px; }
  .bundle-title span { color: var(--green); }
  .bundle-desc { font-size: 13px; color: var(--text-dim); line-height: 1.75; margin-bottom: 12px; }
  .bundle-desc a { color: var(--green); }

  .bundle-features { display: flex; flex-direction: column; gap: 14px; margin-top: 24px; }
  .bundle-feature { display: flex; gap: 14px; align-items: flex-start; }
  .feature-icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
  .feature-title { font-size: 13px; font-weight: 600; color: var(--text-bright); margin-bottom: 2px; font-family: var(--sans); }
  .feature-desc { font-size: 12px; color: var(--text-dim); line-height: 1.6; }

  /* Pricing card */
  .bundle-card {
    border: 1px solid rgba(0,255,136,.4);
    background: var(--bg3);
    padding: 28px 24px;
    position: sticky; top: 80px;
  }
  .bundle-price-label { font-size: 12px; letter-spacing: .16em; color: var(--text-dim); margin-bottom: 8px; font-family: var(--mono); }
  .bundle-price { font-family: var(--sans); font-size: 52px; font-weight: 800; color: var(--green); line-height: 1; margin-bottom: 4px; }
  .bundle-price-sub { font-size: 12px; color: var(--text-dim); margin-bottom: 20px; }
  .bundle-list { list-style: none; padding: 0; margin: 0 0 24px; display: flex; flex-direction: column; gap: 8px; border-top: 1px solid var(--border); padding-top: 16px; }
  .bundle-list li { font-size: 13px; color: var(--text); }

  .buy-btn {
    display: block; text-align: center; background: var(--green); color: var(--bg);
    padding: 14px; font-family: var(--mono); font-size: 13px; font-weight: 700;
    letter-spacing: .1em; text-decoration: none; transition: background .15s;
    margin-bottom: 12px;
  }
  .buy-btn:hover { background: #00ffaa; color: var(--bg); }

  .bundle-guarantee { font-size: 12px; color: var(--text-dim); line-height: 1.6; text-align: center; margin-bottom: 16px; }
  .bundle-meta { display: flex; gap: 12px; justify-content: center; font-size: 12px; color: var(--text-dim); font-family: var(--mono); padding-top: 12px; border-top: 1px solid var(--border); }

  /* File tree preview */
  .bundle-preview { border: 1px solid var(--border); background: var(--bg); }
  .preview-label { font-size: 12px; letter-spacing: .16em; color: var(--text-dim); padding: 10px 16px; border-bottom: 1px solid var(--border); font-family: var(--mono); }
  .file-tree { font-family: var(--mono); font-size: 12px; line-height: 1.9; color: var(--text-dim); padding: 16px; margin: 0; overflow-x: auto; }
  .file-tree::selection { background: rgba(0,255,136,.2); }

  /* Newsletter strip */
  .nl-strip { border: 1px solid var(--border); padding: 24px 28px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .nl-title { font-family: var(--sans); font-weight: 700; font-size: 18px; color: var(--text-bright); margin-bottom: 4px; }
  .nl-sub { color: var(--text-dim); font-size: 13px; }

  @media(max-width:600px) {
    .scripts-hero, .section { padding-left: 20px; padding-right: 20px; }
  }
</style>
