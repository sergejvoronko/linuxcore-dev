    <!-- Terraform -->
    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Terraform</title><path d="M1.977 0L8.26 3.67v7.316L1.977 7.315zm7.194 3.886l6.283-3.67v7.315L9.171 11.2zM0 8.73l6.283 3.67V19.7L0 16.045zm9.171 3.67l6.283-3.67V16.045L9.171 19.7z"/></svg>
    <!-- Grafana -->
    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Grafana</title><path d="M18.364 1.636a12 12 0 010 20.728A12 12 0 115.636 2.364a12 12 0 0112.728-.728zM12 3a9 9 0 100 18A9 9 0 0012 3zm.5 2.5a.5.5 0 01.5.5v5.5l3.5 2a.5.5 0 01-.5.866L12 12V6a.5.5 0 01.5-.5z"/></svg>
