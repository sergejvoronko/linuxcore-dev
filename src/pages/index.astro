---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const featured = allPosts
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recent = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Linux Homelab Automation & Self-Hosted AI">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-label">
        <span class="live-dot"></span> linuxcore.dev
      </div>
      <h1 class="hero-title">
        Linux Homelab<br>
        <em class="hero-accent">Automation &amp; AI</em>
      </h1>
      <p class="hero-lead">
        Practical guides on Ansible, Docker, Proxmox, self-hosted AI, monitoring, and
        security — written by a Linux infrastructure engineer who runs this stuff daily.
      </p>
      <div class="hero-ctas">
        <a href="/homelab" class="btn-primary">Explore Homelab →</a>
        <a href="/scripts" class="btn-outline">Free Scripts</a>
      </div>
      <div class="hero-stack">
        {['Ansible', 'Docker', 'Proxmox', 'Ollama', 'Grafana', 'Tailscale', 'Astro'].map(t => (
          <span class="stack-tag">{t}</span>
        ))}
      </div>
    </div>
        <!-- Terminal widget -->
    <div class="terminal" aria-hidden="true">
      <div class="term-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green-dot"></span>
        <span class="term-title">root@homelab ~ bash</span>
      </div>
      <div class="term-body">
        <div><span class="prompt">root@homelab:~#</span> ollama pull llama3.2</div>
        <div class="out ok">✓ model ready on :11434</div>
        <div><span class="prompt">root@homelab:~#</span> docker compose up -d</div>
        <div class="out ok">✓ grafana started on :3000</div>
        <div><span class="prompt">root@homelab:~#</span> ansible-playbook site.yml</div>
        <div class="out ok">✓ PLAY RECAP — ok=24 changed=3</div>
        <div><span class="prompt">root@homelab:~#</span> <span class="blink">▌</span></div>
      </div>
    </div>
  </section>

  <!-- Featured articles -->
  {featured.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <h2 class="section-heading">
          <span class="sh-prefix">$</span> Featured
        </h2>
        <div class="cards-grid">
          {featured.map(post => {
            const section = post.data.section;
            const href = section === 'homelab' ? `/homelab/${post.slug}`
                       : section === 'astro'   ? `/astro/${post.slug}`
                       : `/blog/${post.slug}`;
            return (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                href={href}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                featured={true}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Sections overview -->
  <section class="section alt">
    <div class="section-inner">
      <h2 class="section-heading"><span class="sh-prefix">$</span> Browse by Topic</h2>
      <div class="topics-grid">
        <a href="/homelab" class="topic-card">
          <div class="topic-icon">⚙</div>
          <h3 class="topic-title">Homelab</h3>
          <p class="topic-desc">Ansible, Docker, Proxmox, self-hosted AI, monitoring, VPN, backups.</p>
          <span class="topic-cta">Explore →</span>
        </a>
        <a href="/astro" class="topic-card">
          <div class="topic-icon">◈</div>
          <h3 class="topic-title">Build with Astro</h3>
          <p class="topic-desc">Fast static sites on Cloudflare Pages for ~€12/year. Practical guides from real production builds.</p>
          <span class="topic-cta">Explore →</span>
        </a>
        <a href="/scripts" class="topic-card">
          <div class="topic-icon">#</div>
          <h3 class="topic-title">Free Scripts</h3>
          <p class="topic-desc">Production-ready Bash scripts for hardening, monitoring, backups, and more.</p>
          <span class="topic-cta">Download →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent articles -->
  {recent.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <h2 class="section-heading"><span class="sh-prefix">$</span> Recent Articles</h2>
        <div class="cards-grid">
          {recent.map(post => {
            const section = post.data.section;
            const href = section === 'homelab' ? `/homelab/${post.slug}`
                       : section === 'astro'   ? `/astro/${post.slug}`
                       : `/blog/${post.slug}`;
            return (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                href={href}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Ansible bundle CTA -->
  <section class="section alt">
    <div class="section-inner">
      <div class="product-cta">
        <div class="product-cta-text">
          <p class="cta-eyebrow"><span class="bracket">[</span>digital product<span class="bracket">]</span></p>
          <h2 class="cta-title">Ansible Homelab Bundle</h2>
          <p class="cta-body">
            25 production-ready Ansible files. Five roles covering base hardening, Docker CE,
            SSH/kernel security with CrowdSec, Prometheus/Grafana monitoring, and Ollama with
            automatic GPU detection. Ready to deploy in minutes.
          </p>
          <div class="cta-actions">
            <a href="/go/ansible-bundle" class="btn-primary" target="_blank" rel="noopener">Get the Bundle — €29 →</a>
            <a href="/scripts" class="btn-outline">See all scripts</a>
          </div>
        </div>
        <div class="product-cta-meta">
          <div class="meta-item"><span class="meta-num">25</span><span class="meta-label">Ansible files</span></div>
          <div class="meta-item"><span class="meta-num">5</span><span class="meta-label">roles</span></div>
          <div class="meta-item"><span class="meta-num">5</span><span class="meta-label">playbooks</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="section" id="newsletter">
    <div class="section-inner newsletter-inner">
      <p class="nl-eyebrow"><span class="bracket">[</span>newsletter<span class="bracket">]</span></p>
      <h2 class="nl-title">Stay in the loop</h2>
      <p class="nl-body">New articles, scripts, and homelab tips — no spam, no weekly digest nonsense.</p>
      <form class="nl-form" action="https://assets.mailerlite.com/jsonp/2251405/forms/184104603196851942/subscribe" method="post" target="_blank">
        <input type="email" name="fields[email]" placeholder="your@email.com" required class="nl-input" />
        <button type="submit" class="btn-primary">Subscribe →</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    padding: 5rem 1.5rem 4rem;
    position: relative;
    overflow: hidden;
  }
  /* ── Terminal widget ── */
   .terminal {
    position: absolute; right: 40px; top: 50%; transform: translateY(-50%);
    width: 400px; background: var(--bg2); border: 1px solid var(--border);
    box-shadow: 0 0 40px rgba(240,165,0,0.06);
    font-size: 12px; line-height: 2; font-family: var(--mono);
  }
  @media (max-width: 1050px) { .terminal { display: none; } }
  .term-bar {
    background: var(--bg3); border-bottom: 1px solid var(--border);
    padding: 9px 14px; display: flex; align-items: center; gap: 6px;
  }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .red        { background: #ff5f57; }
  .yellow     { background: #ffbd2e; }
  .green-dot  { background: #28c840; }
  .term-title { color: var(--text-dim); font-size: 10px; letter-spacing: .1em; margin-left: 8px; }
  .term-body  { padding: 14px 16px; color: var(--text-mid); }
  .prompt     { color: var(--amber); margin-right: 6px; }
  .out        { padding-left: 16px; }
  .ok         { color: rgba(78, 202, 139, 0.8); }
  .blink      { animation: blink 1s step-end infinite; }

  /* Subtle grid background */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(240,165,0,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(240,165,0,0.03) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 70% at 30% 50%, black, transparent);
    pointer-events: none;
  }

  .hero-inner {
    max-width: var(--wide-w);
    margin: 0 auto;
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--amber);
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .live-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--amber);
    animation: blink 2s ease-in-out infinite;
  }
  @keyframes blink { 0%,100%{opacity:.4} 50%{opacity:1} }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 700;
    color: var(--text-bright);
    line-height: 1.08;
    margin-bottom: 1.25rem;
  }
  .hero-accent {
    font-style: italic;
    font-weight: 300;
    color: var(--amber);
  }

  .hero-lead {
    font-size: 1.1rem;
    color: var(--text-mid);
    max-width: 48rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .stack-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-dim);
    background: var(--bg2);
    border: 1px solid var(--border-mid);
    padding: 0.25em 0.65em;
    border-radius: 3px;
  }

  /* ── Sections ──────────────────────────────────────── */
  .section { padding: 4rem 1.5rem; }
  .section.alt { background: var(--bg2); }

  .section-inner {
    max-width: var(--wide-w);
    margin: 0 auto;
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sh-prefix { color: var(--amber); }

  /* ── Cards grid ─────────────────────────────────────── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  /* ── Topics grid ────────────────────────────────────── */
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .topic-card {
    display: block;
    padding: 1.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .topic-card:hover {
    border-color: var(--amber-border);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .topic-icon {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
    display: block;
  }
  .topic-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 0.5rem;
    transition: color 0.15s;
  }
  .topic-card:hover .topic-title { color: var(--amber); }
  .topic-desc {
    font-size: 0.87rem;
    color: var(--text-mid);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .topic-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--amber);
    opacity: 0;
    transition: opacity 0.15s;
  }
  .topic-card:hover .topic-cta { opacity: 1; }

  /* ── Product CTA ────────────────────────────────────── */
  .product-cta {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
    padding: 2.5rem;
    background: var(--bg);
    border: 1px solid var(--amber-border);
    border-radius: 10px;
  }

  .cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--amber);
    margin-bottom: 0.6rem;
  }
  .bracket { opacity: 0.4; }

  .cta-title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 0.75rem;
  }
  .cta-body {
    font-size: 0.95rem;
    color: var(--text-mid);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    max-width: 52ch;
  }
  .cta-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .product-cta-meta {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    text-align: center;
  }
  .meta-item { display: flex; flex-direction: column; align-items: center; }
  .meta-num {
    font-family: var(--font-mono);
    font-size: 2rem;
    color: var(--amber);
    line-height: 1;
  }
  .meta-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.2rem;
  }

  /* ── Newsletter ─────────────────────────────────────── */
  .newsletter-inner { text-align: center; max-width: 500px; margin: 0 auto; }

  .nl-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--amber);
    margin-bottom: 0.75rem;
  }
  .nl-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 0.6rem;
  }
  .nl-body {
    font-size: 0.9rem;
    color: var(--text-mid);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .nl-form { display: flex; gap: 0.6rem; flex-wrap: wrap; justify-content: center; }
  .nl-input {
    flex: 1;
    min-width: 200px;
    padding: 0.65rem 1rem;
    background: var(--bg2);
    border: 1px solid var(--border-mid);
    border-radius: 4px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .nl-input:focus { border-color: var(--amber); }
  .nl-input::placeholder { color: var(--text-dim); }

  @media (max-width: 720px) {
    .product-cta {
      grid-template-columns: 1fr;
    }
    .product-cta-meta {
      flex-direction: row;
      justify-content: center;
      gap: 2rem;
    }
  }
</style>
