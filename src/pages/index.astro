---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const featured = allPosts
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const recent = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Linux Infrastructure Guides — Homelab, AWS & Astro">
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "linuxcore.dev",
    "url": "https://linuxcore.dev",
    "description": "Practical Linux infrastructure guides — homelab automation, AWS hybrid setups, and Astro static sites. By Sergej Voronko.",
    "author": {
      "@type": "Person",
      "name": "Sergej Voronko",
      "jobTitle": "SAP Basis Senior Operations Manager",
      "url": "https://linuxcore.dev/about"
    }
  })}</script>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-label reveal" style="animation-delay:0s">
        <span class="live-dot"></span> linuxcore.dev
      </div>
      <h1 class="hero-title reveal" style="animation-delay:0.1s">
        Linux Infrastructure,<br>
        <em class="hero-accent">Built to Last</em>
      </h1>
      <p class="hero-lead reveal" style="animation-delay:0.22s">
        Practical guides on homelab automation, AWS hybrid setups, and building with Astro —
        written by a Linux infrastructure engineer who runs this stack in production every day.
      </p>
      <div class="hero-ctas reveal" style="animation-delay:0.34s">
        <a href="/homelab" class="btn-primary">Homelab →</a>
        <a href="/aws" class="btn-outline">AWS</a>
        <a href="/astro" class="btn-outline">Astro</a>
      </div>
      <div class="hero-stack reveal" style="animation-delay:0.46s">
        {['Ansible', 'Docker', 'Proxmox', 'Ollama', 'Grafana', 'Terraform', 'AWS', 'Astro'].map(t => (
          <span class="stack-tag">{t}</span>
        ))}
      </div>
    </div>
        <!-- Terminal widget -->
    <div class="terminal" aria-hidden="true">
      <div class="term-bar">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green-dot"></span>
        <span class="term-title">root@homelab ~ bash</span>
      </div>
      <div class="term-body">
        <div><span class="prompt">root@homelab:~#</span> ollama pull llama3.2</div>
        <div class="out ok">✓ model ready on :11434</div>
        <div><span class="prompt">root@homelab:~#</span> docker compose up -d</div>
        <div class="out ok">✓ grafana started on :3000</div>
        <div><span class="prompt">root@homelab:~#</span> ansible-playbook site.yml</div>
        <div class="out ok">✓ PLAY RECAP — ok=24 changed=3</div>
        <div><span class="prompt">root@homelab:~#</span> <span class="blink">▌</span></div>
      </div>
    </div>
  </section>

  <!-- Tech strip -->
  <div class="tech-strip" aria-hidden="true">
    <!-- Linux -->
    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Linux</title><path d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.452-.523 1.933-.755 1.597-1.59 2.59-2.037 3.57-.764 1.681-.845 3.432-.214 5.532.574 1.9 1.737 3.521 3.323 4.617.744.503 1.537.797 2.296 1.148 1.049.495 1.474 1.38 1.474 2.24v.04c0 .28.23.51.514.51h.01c.284 0 .514-.23.514-.51v-.04c0-1.1-.568-2.152-1.82-2.74-.697-.327-1.418-.607-2.07-1.04-1.36-.908-2.38-2.3-2.892-3.952-.472-1.568-.375-3.0.268-4.388.39-.855 1.15-1.79 1.882-3.318.23-.49.527-1.063.61-2.29.064-1.227-.696-4.552 2.278-4.794.107-.008.214-.012.322-.012 2.37 0 3.77 1.87 4.072 4.054.048.35.072.706.072 1.065 0 1.25-.292 2.494-.842 3.57-.22.43-.48.84-.74 1.254-.264.42-.535.84-.754 1.29-.438.9-.618 1.85-.517 2.8.104.974.513 1.87 1.197 2.655.67.77 1.54 1.33 2.565 1.68.433.146.88.238 1.338.295.14.017.28.025.415.025 1.75 0 3.375-.894 4.23-2.344.428-.726.658-1.56.658-2.396 0-.93-.26-1.855-.756-2.645-.252-.4-.552-.762-.877-1.096-.33-.34-.672-.663-.99-1.01-.633-.69-1.098-1.46-1.098-2.467 0-.05.002-.1.006-.15.048-.806.486-1.544 1.21-2.032.686-.463 1.524-.615 2.3-.41.677.18 1.24.638 1.53 1.258.09.19.148.394.17.6.11.994-.472 1.888-1.334 2.253"/></svg>
