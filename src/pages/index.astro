    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Docker</title><path d="M13.983 11.078h2.119a.186.186 0 00.186-.185V9.006a.186.186 0 00-.186-.186h-2.119a.185.185 0 00-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 00.186-.186V3.574a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.888c0 .102.082.185.185.185m0 2.716h2.118a.187.187 0 00.186-.186V6.29a.186.186 0 00-.186-.185h-2.118a.185.185 0 00-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 00.184-.186V6.29a.185.185 0 00-.185-.185H8.1a.185.185 0 00-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 00.185-.186V6.29a.185.185 0 00-.185-.185H5.136a.186.186 0 00-.186.185v1.887c0 .102.084.185.186.186m-2.956 0H3.23a.187.187 0 00.187-.186V6.29a.186.186 0 00-.187-.185H2.18a.186.186 0 00-.186.185v1.887c0 .102.083.185.186.186m2.93 2.715h2.12a.186.186 0 00.184-.185V9.006a.185.185 0 00-.185-.186H5.135a.186.186 0 00-.186.186v1.887c0 .101.084.185.186.185m-2.956 0H3.23a.187.187 0 00.187-.185V9.006a.186.186 0 00-.187-.186H2.18a.186.186 0 00-.186.186v1.887c0 .101.083.185.186.185M24 10.25c-.203-1.37-1.168-2.534-2.68-3.405-.574-5.038-4.09-7.882-4.298-8.05-.16-.126-.39-.123-.545.008-.11.09-2.702 2.218-3.278 5.528-.3.171-.59.355-.86.555H7.062a.181.181 0 00-.181.181v.715c-.45.309-.873.65-1.258 1.024H.186A.186.186 0 000 6.992v7.336c0 2.586 5.366 4.48 12 4.48s12-1.894 12-4.48v-1.17c.314-.57.476-1.19.476-1.829a3.45 3.45 0 00-.476-1.079"/></svg>
    <!-- Ansible -->
    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Ansible</title><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-.116 4.894c3.716 0 6.744 3.028 6.744 6.744 0 3.715-3.028 6.744-6.744 6.744-3.716 0-6.744-3.029-6.744-6.744 0-3.716 3.028-6.744 6.744-6.744zm2.779 9.522l-3.06-7.18a.34.34 0 00-.315-.212.343.343 0 00-.317.212L8.31 14.066a.294.294 0 00.274.404.31.31 0 00.286-.2l.893-2.12 3.233 3.217a.435.435 0 00.305.127.428.428 0 00.429-.427.44.44 0 00-.122-.3l-3.044-3.028 2.006-4.742 2.503 5.875a.31.31 0 00.286.2.294.294 0 00.274-.404l-.048-.115z"/></svg>
