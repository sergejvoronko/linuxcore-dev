    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Astro</title><path d="M8.358 18.95c-.473-.223-.84-.592-1.045-1.075L4.19 8.666c-.397-1.01.175-2.13 1.18-2.512l7.68-2.887c.503-.189 1.055-.15 1.527.107.473.257.81.698.935 1.215l2.027 8.503c.248 1.042-.39 2.093-1.43 2.36l-7.751 1.498zm.623 1.578l7.75-1.499c1.85-.45 3.007-2.292 2.55-4.14l-2.027-8.503a3.427 3.427 0 00-1.588-2.063 3.427 3.427 0 00-2.594-.183L5.392 7.027a3.386 3.386 0 00-2.005 4.273l3.123 9.209a3.377 3.377 0 001.777 1.827 3.38 3.38 0 002.294.192z"/></svg>
  </div>

  <!-- Featured articles -->
  {featured.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <h2 class="section-heading">
          <span class="sh-host">root@linuxcore</span><span class="sh-sep">:~#</span> cat featured
        </h2>
        <div class="cards-grid">
          {featured.map(post => {
            const section = post.data.section;
            const href = section === 'homelab' ? `/homelab/${post.slug}`
                       : section === 'astro'   ? `/astro/${post.slug}`
                       : `/blog/${post.slug}`;
            return (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                href={href}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                featured={true}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Sections overview -->
  <section class="section alt">
    <div class="section-inner">
      <h2 class="section-heading"><span class="sh-host">root@linuxcore</span><span class="sh-sep">:~#</span> ls topics/</h2>
      <div class="topics-grid">
        <a href="/homelab" class="topic-card">
          <div class="topic-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="5" rx="1"/><rect x="2" y="10" width="20" height="5" rx="1"/><circle cx="6" cy="5.5" r="1" fill="currentColor" stroke="none"/><circle cx="6" cy="12.5" r="1" fill="currentColor" stroke="none"/><path d="M2 19h8m4 0h8"/><path d="M12 17v4"/></svg>
          </div>
          <h3 class="topic-title">Homelab</h3>
          <p class="topic-desc">Ansible, Docker, Proxmox, self-hosted AI, Grafana monitoring, WireGuard — built for reliability, not just tutorials.</p>
          <span class="topic-cta">Explore →</span>
        </a>
        <a href="/astro" class="topic-card">
          <div class="topic-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L2 19.5h20L12 2z"/><path d="M12 2v11"/><path d="M7 14l5-3 5 3"/></svg>
          </div>
          <h3 class="topic-title">Build with Astro</h3>
          <p class="topic-desc">Fast static sites on Cloudflare Pages for ~€12/year. Practical guides from real production builds.</p>
          <span class="topic-cta">Explore →</span>
        </a>
        <a href="/aws" class="topic-card">
          <div class="topic-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18a7 7 0 010-12 5 5 0 019.9-1A6 6 0 1118 18H3z"/></svg>
          </div>
          <h3 class="topic-title">AWS</h3>
          <p class="topic-desc">Cost-effective cloud for homelab operators — spot instances, S3 backups, hybrid setups, and Terraform. Real numbers, no fluff.</p>
          <span class="topic-cta">Explore →</span>
        </a>
        <a href="/scripts" class="topic-card">
          <div class="topic-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
          </div>
          <h3 class="topic-title">Free Scripts</h3>
          <p class="topic-desc">Production-ready Bash scripts for server hardening, monitoring, and offsite backups — free to download and use.</p>
          <span class="topic-cta">Download →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent articles -->
  {recent.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <h2 class="section-heading"><span class="sh-host">root@linuxcore</span><span class="sh-sep">:~#</span> ls -lt articles/</h2>
        <div class="cards-grid">
          {recent.map(post => {
            const section = post.data.section;
            const href = section === 'homelab' ? `/homelab/${post.slug}`
                       : section === 'astro'   ? `/astro/${post.slug}`
                       : `/blog/${post.slug}`;
            return (
              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                href={href}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
              />
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Ansible bundle CTA -->
  <section class="section alt">
    <div class="section-inner">
      <div class="product-cta">
        <div class="product-cta-text">
          <p class="cta-eyebrow"><span class="bracket">[</span>digital product<span class="bracket">]</span></p>
