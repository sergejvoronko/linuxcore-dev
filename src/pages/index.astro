    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Proxmox</title><path d="M2.332 8.625l4.42 2.56v5.116l4.416 2.557V9.185L2.332 4.513v4.112zm19.336 0V4.513L12.83 9.185v9.673l4.417-2.557V11.185l4.421-2.56zM12 1.068L3.247 6.12l8.754 5.063 8.752-5.063L12 1.068z"/></svg>
