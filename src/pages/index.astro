    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Cloudflare</title><path d="M16.478 15.126l1.419-4.862c.145-.497.089-.955-.155-1.287-.232-.317-.619-.497-1.073-.51l-9.784-.129c-.088-.001-.161.038-.205.107a.245.245 0 00-.018.232l.459 1.208c.065.172.252.294.459.307l6.68.38c.223.013.386.183.376.383-.01.2-.188.358-.412.358H8.894c-.088-.001-.161.039-.205.108a.244.244 0 00-.017.232l.43 1.134c.066.172.252.294.459.306l5.782.329c.226.013.394.186.385.388-.009.2-.184.355-.41.355H9.737c-.088 0-.162.04-.205.11-.043.07-.046.155-.008.227.774 1.508 2.214 2.392 3.905 2.392h.001c1.763 0 3.484-.985 4.18-2.405a.38.38 0 00-.015-.378.38.38 0 00-.315-.18l-.802-.028zM22.737 10.368a5.995 5.995 0 00-.168-.59 4.947 4.947 0 00-.098-.27c-.013-.034-.024-.069-.038-.102a5.618 5.618 0 00-.177-.38l-.046-.089a5.543 5.543 0 00-.234-.397l-.053-.08a5.46 5.46 0 00-.278-.366l-.059-.07a5.496 5.496 0 00-.308-.327l-.067-.065a5.553 5.553 0 00-.337-.285l-.072-.056a5.6 5.6 0 00-.366-.248l-.073-.045a5.63 5.63 0 00-.39-.21l-.072-.034a5.656 5.656 0 00-.413-.172l-.07-.025a5.688 5.688 0 00-.435-.132l-.068-.016a5.714 5.714 0 00-.453-.092l-.064-.01a5.734 5.734 0 00-.47-.05l-.062-.005A5.755 5.755 0 0018 7.3l-.023.001C17.01 4.266 14.244 2.1 11 2.1c-2.742 0-5.145 1.528-6.438 3.806a4.157 4.157 0 00-.562-.038C1.793 5.868 0 7.662 0 9.868c0 2.205 1.793 3.993 4 3.993h18c1.105 0 2-.896 2-2a2.015 2.015 0 00-1.263-1.493z"/></svg>
    <!-- AWS -->
    <svg viewBox="0 0 24 24" fill="currentColor" class="tech-icon"><title>Amazon Web Services</title><path d="M6.763 10.036c0 .296.032.535.088.71.064.176.144.368.256.576.04.063.056.127.056.183 0 .08-.048.16-.152.24l-.503.335a.383.383 0 01-.208.072c-.08 0-.16-.04-.239-.112a2.47 2.47 0 01-.287-.375 6.18 6.18 0 01-.248-.471c-.622.734-1.405 1.101-2.347 1.101-.67 0-1.205-.191-1.596-.574-.391-.384-.59-.894-.59-1.533 0-.678.239-1.23.726-1.644.487-.415 1.133-.623 1.955-.623.272 0 .551.024.846.064.296.04.6.104.918.176v-.583c0-.607-.127-1.03-.375-1.277-.255-.248-.686-.367-1.3-.367-.28 0-.568.031-.863.103-.295.072-.583.16-.862.272a2.287 2.287 0 01-.28.104.488.488 0 01-.127.023c-.112 0-.168-.08-.168-.247v-.391c0-.128.016-.224.056-.28a.597.597 0 01.224-.167c.279-.144.614-.264 1.005-.36a4.84 4.84 0 011.246-.151c.95 0 1.644.216 2.091.647.439.43.662 1.085.662 1.963v2.586zm-3.24 1.214c.263 0 .534-.048.822-.144.287-.096.543-.271.758-.51.128-.152.224-.32.272-.512.047-.191.08-.423.08-.694v-.335a6.66 6.66 0 00-.735-.136 6.02 6.02 0 00-.75-.048c-.535 0-.926.104-1.19.32-.263.215-.39.518-.39.917 0 .375.095.655.295.846.191.2.47.296.838.296zm6.41.862c-.144 0-.240-.024-.304-.08-.063-.048-.12-.16-.168-.311L7.586 5.55a1.398 1.398 0 01-.072-.32c0-.128.064-.2.191-.2h.783c.151 0 .255.025.31.08.065.048.113.16.16.312l1.342 5.284 1.245-5.284c.04-.16.088-.264.151-.312a.549.549 0 01.32-.08h.638c.152 0 .256.025.32.08.063.048.12.16.151.312l1.261 5.348 1.381-5.348c.048-.16.104-.264.16-.312a.52.52 0 01.311-.08h.743c.127 0 .2.065.2.2 0 .04-.009.08-.017.128a1.137 1.137 0 01-.056.2l-1.923 6.17c-.048.16-.104.264-.168.311a.51.51 0 01-.303.08h-.687c-.151 0-.255-.024-.32-.08-.063-.056-.119-.16-.15-.32l-1.238-5.148-1.23 5.14c-.04.16-.087.264-.15.32-.065.056-.177.08-.32.08h-.686zm10.105.215c-.413 0-.83-.048-1.229-.143-.399-.096-.71-.2-.918-.32-.128-.071-.215-.151-.247-.223a.563.563 0 01-.048-.224v-.407c0-.167.064-.247.183-.247.048 0 .096.008.144.024.048.016.12.048.2.08.271.12.566.215.878.279.319.064.63.096.95.096.5