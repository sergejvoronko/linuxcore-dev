---
// src/pages/homelab/[slug].astro
// Option 1: thin wrapper that reuses the master blog post page.
// getStaticPaths filters to section === 'homelab' so only homelab posts
// appear under /homelab/slug. Rendering is fully handled by PostLayout.

import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    data.section === 'homelab' && !data.draft
  );
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, tags, readingTime, section, affiliate, faqs } = post.data;
---

<PostLayout
  {title}
  {description}
  {pubDate}
  {updatedDate}
  {heroImage}
  {heroImageAlt}
  {tags}
  {readingTime}
  {section}
  {headings}
  {affiliate}
  {faqs}
>
  <Content />
</PostLayout>
