---
// src/pages/aws/[slug].astro
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    data.section === 'aws' && !data.draft
  );
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, tags, readingTime, section, affiliate, faqs } = post.data;
---

<PostLayout
  {title}
  {description}
  {pubDate}
  {updatedDate}
  {heroImage}
  {heroImageAlt}
  {tags}
  {readingTime}
  {section}
  {headings}
  {affiliate}
  {faqs}
  slug={post.id}
>
  <Content />
</PostLayout>
