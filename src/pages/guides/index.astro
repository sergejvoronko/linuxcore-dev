---
// src/pages/guides/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const sorted    = allGuides.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pillars = ['All', 'Self-Hosted AI', 'Linux Automation', 'Infrastructure', 'Monitoring', 'Security', 'AWS Hybrid'];
---

<BaseLayout title="Guides" description="All Linux, AI homelab, and automation guides on linuxcore.dev.">
  <section class="guides-page">
    <div class="guides-inner">

      <header class="guides-header">
        <div class="section-label">ALL GUIDES</div>
        <h1 class="guides-title">Every article, <span>searchable.</span></h1>
        <p class="guides-desc">{sorted.length} guides across Linux automation, self-hosted AI, monitoring, security, and AWS hybrid.</p>
      </header>

      <!-- Filter buttons (JS-powered) -->
      <div class="filter-bar" id="filters">
        {pillars.map(p => (
          <button class:list={['filter-btn', { active: p === 'All' }]} data-pillar={p}>
            {p}
          </button>
        ))}
      </div>

      <!-- Posts grid -->
      <div class="posts-grid" id="posts-grid">
        {sorted.map(post => (
          <div class="post-item" data-pillar={post.data.pillar}>
            <PostCard post={post} />
          </div>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .guides-page { padding: 48px 40px 80px; }
  .guides-inner { max-width: 1100px; margin: 0 auto; }
  .guides-header { margin-bottom: 36px; }
  .section-label { font-size: 10px; letter-spacing: .2em; color: var(--green); margin-bottom: 8px; }
  .section-label::before { content: '// '; color: var(--text-dim); }
  .guides-title { font-family: var(--sans); font-weight: 800; font-size: clamp(24px, 3vw, 40px); color: var(--text-bright); margin-bottom: 10px; }
  .guides-title span { color: var(--green); }
  .guides-desc { color: var(--text-dim); font-size: 13px; }

  .filter-bar { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
  .filter-btn { background: transparent; border: 1px solid var(--border); color: var(--text-dim); padding: 6px 14px; font-family: var(--mono); font-size: 11px; letter-spacing: .08em; cursor: pointer; transition: all .15s; }
  .filter-btn:hover { border-color: var(--green); color: var(--green); }
  .filter-btn.active { background: var(--green); color: var(--bg); border-color: var(--green); font-weight: 700; }

  .posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 16px; }
  .post-item { transition: opacity .2s; }
  .post-item.hidden { display: none; }

  @media (max-width: 600px) { .guides-page { padding: 32px 20px; } }
</style>

<script>
  // Client-side filtering — no page reload
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items   = document.querySelectorAll<HTMLElement>('.post-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const pillar = btn.dataset.pillar ?? 'All';

      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      items.forEach(item => {
        const show = pillar === 'All' || item.dataset.pillar === pillar;
        item.classList.toggle('hidden', !show);
      });
    });
  });
</script>
