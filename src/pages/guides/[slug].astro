---
// src/pages/guides/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props:  { guide },
  }));
}

const { guide } = Astro.props;
const { Content, headings } = await guide.render();

const { title, description, pubDate, updatedDate, pillar, type, tags, readTime, heroImage } = guide.data;

const pillarColors: Record<string, string> = {
  'Infrastructure':   '#f0a500',
  'Self-Hosted AI':   '#7eb8d4',
  'Linux Automation': '#f0a500',
  'Monitoring':       '#c49a6c',
  'Security':         '#ff6b6b',
  'AWS Hybrid':       '#f0a500',
};
const color = pillarColors[pillar] ?? '#f0a500';

const formatDate = (d: Date) => new Date(d).toLocaleDateString('en-GB', {
  day: '2-digit', month: 'long', year: 'numeric'
});

const tocHeadings = headings.filter((h: any) => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 2;
---

<BaseLayout title={title} description={description} image={heroImage}>
  <div class="post-page">

    <!-- Full-width header -->
    <header class="post-header">
      <div class="post-tags">
        <span class="tag-pill" style={`color:${color}; border-color:${color}44; background:${color}11`}>{pillar}</span>
        <span class="tag-pill dimmed">{type}</span>
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-desc">{description}</p>
      <div class="post-meta">
        <span>📅 {formatDate(pubDate)}</span>
        {updatedDate && <span>↻ Updated {formatDate(updatedDate)}</span>}
        <span>⏱ {readTime} min read</span>
      </div>
      <div class="header-line"></div>
    </header>

    <!-- Two-column: article + sticky TOC -->
    <div class:list={['post-layout', { 'has-toc': hasToc }]}>

      <article class="post-article">
        {heroImage && (
          <div class="post-hero">
            <img src={heroImage} alt={title} width="1200" height="630" loading="eager" />
          </div>
        )}

        <div class="prose-content">
          <Content />
        </div>

        <footer class="post-footer">
          <div class="tag-list">
            {tags.map((tag: string) => (
              <a href={`/guides?tag=${tag}`} class="post-tag">#{tag}</a>
            ))}
          </div>
          <a href="/guides" class="back-link">← All guides</a>
        </footer>
      </article>

      {hasToc && (
        <aside class="toc-sidebar">
          <TableOfContents headings={headings} />
        </aside>
      )}

    </div>
  </div>
</BaseLayout>

<style>
  .post-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px 80px;
  }
  @media (max-width: 600px) { .post-page { padding: 0 18px 60px; } }

  /* ── Header ─────────────────────────────────────────────── */
  .post-header {
    max-width: 860px;
    padding: 44px 0 0;
    margin-bottom: 40px;
  }

  .post-tags { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .tag-pill {
    font-size: 9px; letter-spacing: 0.14em; font-weight: 700;
    padding: 3px 10px; border: 1px solid;
    font-family: var(--mono);
  }
  .tag-pill.dimmed { color: var(--text-dim); border-color: var(--border); }

  .post-title {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(28px, 4vw, 48px);
    color: var(--text-bright);
    line-height: 1.12;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
  }

  .post-desc {
    color: var(--text-mid);
    font-size: 19px;
    line-height: 1.65;
    margin-bottom: 18px;
    font-weight: 300;
  }

  .post-meta {
    display: flex; gap: 20px;
    font-size: 11px; color: var(--text-dim);
    flex-wrap: wrap;
    font-family: var(--mono);
    letter-spacing: 0.04em;
  }

  .header-line { height: 1px; background: var(--border); margin-top: 24px; }

  /* ── Two-column layout ──────────────────────────────────── */
  .post-layout { display: block; }

  .post-layout.has-toc {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 56px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .post-layout.has-toc { display: block; }
    .toc-sidebar { display: none; }
  }

  /* ── Sticky TOC ─────────────────────────────────────────── */
  .toc-sidebar {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  /* ── Hero image ─────────────────────────────────────────── */
  .post-hero { margin-bottom: 32px; border: 1px solid var(--border); }
  .post-hero img { width: 100%; height: auto; display: block; }

  /* ── Prose ──────────────────────────────────────────────── */
  .prose-content {
    color: var(--text);
    font-family: var(--sans);
    font-size: 18px;
    line-height: 1.85;
    min-width: 0;
  }

  .prose-content :global(h2) {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(22px, 2.5vw, 30px);
    color: var(--text-bright);
    letter-spacing: -0.02em;
    margin: 2.2em 0 0.7em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    scroll-margin-top: 90px;
  }

  .prose-content :global(h3) {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 20px;
    color: var(--amber);
    margin: 1.8em 0 0.5em;
    scroll-margin-top: 90px;
  }

  .prose-content :global(h4) {
    font-weight: 600;
    font-size: 17px;
    color: var(--text-bright);
    margin: 1.4em 0 0.4em;
  }

  .prose-content :global(p) { margin-bottom: 1.3em; }

  .prose-content :global(a) {
    color: var(--amber);
    border-bottom: 1px dashed rgba(240,165,0,0.35);
    transition: border-color 0.15s;
  }
  .prose-content :global(a:hover) { border-bottom-color: var(--amber); }

  .prose-content :global(ul),
  .prose-content :global(ol) { padding-left: 1.5em; margin-bottom: 1.3em; }
  .prose-content :global(li) { margin-bottom: 0.5em; }
  .prose-content :global(li::marker) { color: var(--amber); }

  .prose-content :global(strong) { color: var(--text-bright); font-weight: 600; }

  .prose-content :global(blockquote) {
    border-left: 3px solid var(--amber);
    padding: 12px 20px;
    margin: 1.5em 0;
    background: var(--amber-glow);
    color: var(--text-mid);
    font-style: italic;
    font-size: 15px;
  }

  .prose-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5em 0;
  }

  .prose-content :global(table) {
    border: 1px solid var(--border);
    width: 100%; border-collapse: collapse;
    margin: 1.5em 0;
    font-family: var(--mono); font-size: 14px;
  }
  .prose-content :global(th) {
    background: var(--bg3); color: var(--amber);
    font-size: 11px; letter-spacing: 0.1em; font-weight: 700;
    padding: 12px 16px; text-align: left;
    border-bottom: 1px solid var(--border-amber);
  }
  .prose-content :global(td) {
    padding: 12px 16px; border-bottom: 1px solid var(--border);
    vertical-align: top;
    font-family: var(--sans); font-size: 16px;
  }
  .prose-content :global(tr:last-child td) { border-bottom: none; }
  .prose-content :global(tr:hover td) { background: rgba(240,165,0,0.03); }

  /* ── Footer ─────────────────────────────────────────────── */
  .post-footer {
    margin-top: 56px; padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between;
    align-items: flex-start; flex-wrap: wrap; gap: 16px;
  }
  .tag-list { display: flex; gap: 8px; flex-wrap: wrap; }
  .post-tag {
    color: var(--text-dim); font-size: 11px;
    border: 1px solid var(--border); padding: 2px 8px;
    text-decoration: none; transition: all 0.15s;
    font-family: var(--mono);
  }
  .post-tag:hover { border-color: var(--amber); color: var(--amber); }
  .back-link {
    color: var(--text-dim); font-size: 12px;
    text-decoration: none; transition: color 0.15s;
    font-family: var(--mono);
  }
  .back-link:hover { color: var(--amber); }
</style>
