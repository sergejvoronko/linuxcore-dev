---
// src/pages/shop/product/[id].astro
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';
import { getProduct, getProducts, getBasePrice, getDefaultImage, formatPrice } from '../../../lib/printify';

const env = (Astro.locals as any).runtime?.env;
const { id } = Astro.params;
let product: any = null;
let fetchError = '';
let related: any[] = [];

try {
  product = await getProduct(id!, env);
} catch (e: any) {
  fetchError = e.message;
}

try {
  const all = await getProducts(env);
  related = all.filter((p: any) => p.id !== id).slice(0, 3);
} catch { /* non-critical */ }

const enabledVariants = product?.variants?.filter((v: any) => v.is_enabled) ?? [];
const images = product?.images?.slice(0, 6) ?? [];
---

<BaseLayout
  title={product?.title ?? 'Product'}
  description={product?.description?.replace(/<[^>]+>/g, '').slice(0, 160) ?? ''}
  heroImage={images[0]?.src}
>
  <main class="product-page">

    {fetchError && (
      <div class="error-state">
        <p>Could not load product: <code>{fetchError}</code></p>
        <a href="/shop">← Back to shop</a>
      </div>
    )}

    {product && (
      <>
        <div class="product-layout">

          <!-- Gallery -->
          <div class="gallery">
            <div class="gallery-main">
              <img id="main-img" src={images[0]?.src ?? '/images/placeholder-product.png'} alt={product.title} width="800" height="800" />
            </div>
            {images.length > 1 && (
              <div class="gallery-thumbs">
                {images.map((img: any, i: number) => (
                  <button class={`thumb ${i === 0 ? 'active' : ''}`} data-src={img.src} aria-label={`View image ${i + 1}`}>
                    <img src={img.src} alt={`${product.title} view ${i + 1}`} width="80" height="80" loading="lazy" />
                  </button>
                ))}
              </div>
            )}
          </div>

          <!-- Buy box (title, price, variants, qty, CTA) -->
          <div class="product-details">
            <div class="back-link"><a href="/shop">← Shop</a></div>
            <h1 class="product-title">{product.title}</h1>
            <div class="product-price-display" id="price-display">
              {formatPrice(getBasePrice(product))}
            </div>

            <!-- Variant selector -->
            {enabledVariants.length > 0 && (
              <div class="variants">
                <label class="variant-label">Select option</label>
                <select id="variant-select" class="variant-select">
                  {enabledVariants.map((v: any) => (
                    <option
                      value={v.id}
                      data-price={v.price}
                      data-title={v.title}
                    >
                      {v.title} — {formatPrice(v.price)}
                    </option>
                  ))}
                </select>
              </div>
            )}

            <!-- Quantity -->
            <div class="quantity-row">
              <label class="variant-label" for="quantity">Quantity</label>
              <div class="qty-control">
                <button class="qty-btn" id="qty-minus" aria-label="Decrease quantity">−</button>
                <input type="number" id="quantity" value="1" min="1" max="10" class="qty-input" />
                <button class="qty-btn" id="qty-plus" aria-label="Increase quantity">+</button>
              </div>
            </div>

            <button class="btn-primary buy-btn" id="buy-btn">
              Buy Now →
            </button>
            <div id="buy-status" class="buy-status" aria-live="polite"></div>
          </div>

        </div>

        <!-- Full-width description below the buy-box grid -->
        {product.description && (
          <div class="product-desc" set:html={product.description} />
        )}

        <!-- More from the shop -->
        {related.length > 0 && (
          <section class="related-section">
            <div class="related-label"><span class="tb">[</span>also in the shop<span class="tb">]</span></div>
            <div class="related-grid">
              {related.map((p: any) => (
                <a href={`/shop/product/${p.id}`} class="related-card">
                  <div class="related-img-wrap">
                    <img src={getDefaultImage(p)} alt={p.title} width="300" height="300" loading="lazy" />
                  </div>
                  <div class="related-info">
                    <div class="related-name">{p.title}</div>
                    <div class="related-price">from {formatPrice(getBasePrice(p))}</div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Digital upsell -->
        <section class="upsell-block">
          <div class="upsell-eye"><span class="tb">[</span>digital product<span class="tb">]</span></div>
          <div class="upsell-inner">
            <div class="upsell-text">
              <h2 class="upsell-title">Ansible Homelab Bundle</h2>
              <p class="upsell-desc">
                25 production-ready Ansible files — base hardening, Docker CE, SSH security,
                Grafana monitoring, and Ollama with auto GPU detection. Provision a fresh Ubuntu
                box to full homelab stack in 8 minutes.
              </p>
            </div>
            <a href="/go/ansible-bundle" class="btn-primary upsell-btn" target="_blank" rel="noopener">
              Get the Bundle — €29 →
            </a>
          </div>
        </section>

        <!-- Newsletter -->
        <div class="nl-wrap">
          <NewsletterForm
            compact={true}
            title="Get notified when new designs drop"
            description="New merch, new articles, new scripts. No noise — one email per release."
          />
        </div>
      </>
    )}

  </main>
</BaseLayout>

<style>
  .product-page { max-width: var(--wide-w); margin: 0 auto; padding: 3rem 1.5rem 5rem; }

  .error-state { text-align: center; padding: 4rem; color: var(--text-mid); }
  .error-state code { color: var(--red); }
  .error-state a { color: var(--amber); }

  .back-link { margin-bottom: 1rem; }
  .back-link a { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-dim); text-decoration: none; }
  .back-link a:hover { color: var(--amber); }

  .product-layout { display: grid; grid-template-columns: minmax(0, 480px) minmax(0, 400px); gap: 3rem; align-items: start; justify-content: start; }

  /* Gallery */
  .gallery { display: flex; flex-direction: column; gap: 0.75rem; }
  .gallery-main { border-radius: 10px; overflow: hidden; background: var(--bg2); border: 1px solid var(--border); }
  .gallery-main img { width: 100%; height: auto; display: block; }
  .gallery-thumbs { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .thumb { background: var(--bg2); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; padding: 0; cursor: pointer; width: 72px; height: 72px; transition: border-color 0.15s; }
  .thumb.active, .thumb:hover { border-color: var(--amber); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Details */
  .product-title { font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; color: var(--text-bright); margin-bottom: 0.6rem; line-height: 1.2; }
  .product-price-display { font-family: var(--font-mono); font-size: 1.5rem; color: var(--amber); margin-bottom: 1.5rem; }

  /* Variants */
  .variants { margin-bottom: 1.25rem; }
  .variant-label { display: block; font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.5rem; }
  .variant-select { width: 100%; padding: 0.65rem 1rem; background: var(--bg2); border: 1px solid var(--border-mid); border-radius: 6px; color: var(--text); font-family: var(--font-body); font-size: 0.93rem; outline: none; cursor: pointer; transition: border-color 0.15s; }
  .variant-select:focus { border-color: var(--amber); }

  /* Quantity */
  .quantity-row { margin-bottom: 1.75rem; }
  .qty-control { display: flex; align-items: center; gap: 0; border: 1px solid var(--border-mid); border-radius: 6px; overflow: hidden; width: fit-content; }
  .qty-btn { width: 40px; height: 40px; background: var(--bg2); border: none; color: var(--text); font-size: 1.1rem; cursor: pointer; transition: background 0.15s; }
  .qty-btn:hover { background: var(--amber-dim); color: var(--amber); }
  .qty-input { width: 52px; height: 40px; background: var(--bg2); border: none; border-left: 1px solid var(--border-mid); border-right: 1px solid var(--border-mid); color: var(--text); font-family: var(--font-mono); font-size: 0.9rem; text-align: center; outline: none; }

  .buy-btn { width: 100%; font-size: 0.9rem; padding: 0.85rem 1.5rem; margin-bottom: 0.75rem; }

  .buy-status { font-family: var(--font-mono); font-size: 0.78rem; color: var(--red); min-height: 1.2em; }

  .product-desc { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border); font-size: 0.9rem; color: var(--text-mid); line-height: 1.7; max-width: 860px; }
  .product-desc :global(p) { margin-bottom: 0.8em; }
  .product-desc :global(table) {
    width: 100%; border-collapse: collapse; margin-bottom: 1.5rem;
    display: block; overflow-x: auto; white-space: nowrap;
  }
  .product-desc :global(th) {
    padding: 0.5rem 0.9rem;
    background: rgba(240,165,0,0.08);
    border: 1px solid rgba(240,165,0,0.25);
    color: var(--amber);
    font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.06em;
    text-align: center; white-space: nowrap;
  }
  .product-desc :global(td) {
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--border);
    font-size: 0.82rem; text-align: center; white-space: nowrap;
    color: var(--text-mid);
  }
  .product-desc :global(tr:nth-child(even) td) { background: var(--bg2); }
  .product-desc :global(td:first-child) { text-align: left; white-space: normal; min-width: 140px; color: var(--text); font-family: var(--font-mono); font-size: 0.78rem; }
  .product-desc :global(h1), .product-desc :global(h2), .product-desc :global(h3) { font-family: var(--font-display); color: var(--text-bright); margin: 1.25rem 0 0.5rem; font-size: 1rem; font-weight: 700; }
  .product-desc :global(ul), .product-desc :global(ol) { padding-left: 1.25rem; margin-bottom: 0.8em; }
  .product-desc :global(li) { margin-bottom: 0.25rem; }

  /* Related products */
  .related-section { margin-top: 3.5rem; padding-top: 2.5rem; border-top: 1px solid var(--border); }
  .related-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--amber); margin-bottom: 1.25rem; letter-spacing: 0.08em; }
  .tb { opacity: 0.35; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem; }
  .related-card { text-decoration: none; border: 1px solid var(--border); background: var(--bg2); transition: border-color 0.15s; display: block; }
  .related-card:hover { border-color: var(--amber); }
  .related-img-wrap { aspect-ratio: 1; overflow: hidden; background: var(--bg); }
  .related-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.2s; }
  .related-card:hover .related-img-wrap img { transform: scale(1.04); }
  .related-info { padding: 0.75rem; }
  .related-name { font-size: 0.82rem; color: var(--text); line-height: 1.3; margin-bottom: 0.3rem; }
  .related-price { font-family: var(--font-mono); font-size: 0.75rem; color: var(--amber); }

  /* Digital upsell */
  .upsell-block {
    margin-top: 3rem; padding: 2rem 2.5rem;
    border: 1px solid var(--amber-border);
    background: rgba(240,165,0,0.04);
  }
  .upsell-eye { font-family: var(--font-mono); font-size: 0.7rem; color: var(--amber); margin-bottom: 0.75rem; letter-spacing: 0.08em; }
  .upsell-inner { display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; }
  .upsell-text { flex: 1; min-width: 220px; }
  .upsell-title { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--text-bright); margin-bottom: 0.5rem; }
  .upsell-desc { font-size: 0.88rem; color: var(--text-mid); line-height: 1.65; }
  .upsell-btn { white-space: nowrap; flex-shrink: 0; }

  /* Newsletter */
  .nl-wrap { margin-top: 2.5rem; }

  @media (max-width: 860px) {
    .product-layout { grid-template-columns: 1fr; gap: 2rem; }
    .upsell-inner { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
    .upsell-btn { width: 100%; text-align: center; }
  }
</style>

<script>
  // Gallery
  const mainImg  = document.getElementById('main-img') as HTMLImageElement;
  const thumbs   = document.querySelectorAll<HTMLButtonElement>('.thumb');
  thumbs.forEach(t => {
    t.addEventListener('click', () => {
      mainImg.src = t.dataset.src!;
      thumbs.forEach(x => x.classList.remove('active'));
      t.classList.add('active');
    });
  });

  // Quantity
  const qtyInput = document.getElementById('quantity') as HTMLInputElement;
  document.getElementById('qty-minus')?.addEventListener('click', () => {
    qtyInput.value = String(Math.max(1, Number(qtyInput.value) - 1));
  });
  document.getElementById('qty-plus')?.addEventListener('click', () => {
    qtyInput.value = String(Math.min(10, Number(qtyInput.value) + 1));
  });

  // Variant price update
  const variantSelect  = document.getElementById('variant-select') as HTMLSelectElement;
  const priceDisplay   = document.getElementById('price-display');
  variantSelect?.addEventListener('change', () => {
    const opt = variantSelect.selectedOptions[0] as HTMLOptionElement;
    const price = Number(opt.dataset.price ?? 0);
    if (priceDisplay)
      priceDisplay.textContent = new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR' }).format(price / 100);
  });

  // Buy button → Stripe checkout
  document.getElementById('buy-btn')?.addEventListener('click', async () => {
    const btn    = document.getElementById('buy-btn') as HTMLButtonElement;
    const status = document.getElementById('buy-status') as HTMLDivElement;
    btn.disabled = true;
    btn.textContent = 'Creating checkout…';
    status.textContent = '';

    try {
      const variantId  = Number(variantSelect?.value ?? 0);
      const quantity   = Number(qtyInput?.value ?? 1);
      const productId  = window.location.pathname.split('/').at(-1);

      const res = await fetch('/api/checkout', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, variantId, quantity }),
      });

      const data = await res.json() as { url?: string; error?: string };
      if (data.url) {
        window.location.href = data.url;
      } else {
        throw new Error(data.error ?? 'Checkout failed');
      }
    } catch (err: any) {
      status.textContent = `Error: ${err.message}`;
      btn.disabled = false;
      btn.textContent = 'Buy Now →';
    }
  });
</script>
