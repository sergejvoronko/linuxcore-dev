---
// src/pages/blog/[slug].astro
// Fallback post route for section-less posts only.
// Sectioned posts render at their canonical /homelab|/astro|/aws/[slug]
// route, so they are NOT emitted here — this avoids duplicate (noindexed)
// URLs wasting crawl budget and self-canonicalling to the wrong path.

import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && !data.section);
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const { title, description, pubDate, updatedDate, heroImage, heroImageAlt, tags, readingTime, section, affiliate } = post.data;
---

<PostLayout
  {title}
  {description}
  {pubDate}
  {updatedDate}
  {heroImage}
  {heroImageAlt}
  {tags}
  {readingTime}
  {section}
  {headings}
  {affiliate}
  slug={post.id}
>
  <Content />
</PostLayout>
