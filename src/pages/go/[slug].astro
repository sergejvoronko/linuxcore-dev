---
// src/pages/go/[slug].astro
// Pretty affiliate redirect URLs: /go/beelink-mini-s12 → real affiliate URL
// Add new links in src/data/affiliates.ts — no code changes needed here.

import { affiliates } from '../../data/affiliates';

export function getStaticPaths() {
  return affiliates.map(link => ({
    params: { slug: link.slug },
    props:  { link },
  }));
}

const { link } = Astro.props;

// Redirect immediately via meta refresh + JS
// (Cloudflare Pages static export doesn't support server-side redirects
//  without a _redirects file, but this approach works without a build step)
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Redirecting to {link.label} — linuxcore.dev</title>
  <meta http-equiv="refresh" content={`0;url=${link.destination}`} />
  <link rel="canonical" href={link.destination} />
  <meta name="robots" content="noindex, nofollow" />
  <style>
    body {
      font-family: 'Space Mono', monospace;
      background: #18120a;
      color: #e8dcc8;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
      text-align: center;
      flex-direction: column;
      gap: 1rem;
    }
    .label { font-size: 0.7rem; color: rgb(var(--amber-rgb) / 0.6); text-transform: uppercase; letter-spacing: 0.15em; }
    .name  { font-size: 1.1rem; color: #f0a500; }
    .note  { font-size: 0.75rem; color: rgba(232,220,200,0.4); }
    a      { color: #f0a500; }
  </style>
</head>
<body>
  <div class="label">[redirect]</div>
  <div class="name">{link.label}</div>
  <div class="note">
    Taking you there… <a href={link.destination}>click here</a> if nothing happens.
  </div>
  <script define:vars={{ dest: link.destination }}>
    window.location.replace(dest);
  </script>
</body>
</html>
