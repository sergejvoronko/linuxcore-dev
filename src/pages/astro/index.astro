---
// src/pages/astro/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  data.section === 'astro' && !data.draft
);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = [
  { label: 'All',       tags: [] },
  { label: 'Setup',     tags: ['astro', 'cloudflare', 'github'] },
  { label: 'Comments',  tags: ['giscus', 'comments'] },
  { label: 'Forms',     tags: ['contact', 'forms', 'resend'] },
  { label: 'SEO',       tags: ['seo', 'meta', 'og'] },
  { label: 'Newsletter',tags: ['newsletter', 'mailerlite'] },
  { label: 'Shop',      tags: ['shop', 'printify', 'stripe'] },
];
---

<BaseLayout
  title="Build with Astro"
  description="Practical guides on building fast, cheap, low-maintenance websites with Astro, GitHub, and Cloudflare Pages. Written by a sysadmin who uses this stack in production."
>
  <main class="section-page">

    <section class="section-hero">
      <img src="/images/section-astro.webp" alt="" class="hero-photo" width="1280" height="720" aria-hidden="true" />
      <div class="hero-bg"></div>
      <div class="hero-content">
        <div class="tag-label"><span class="tb">[</span>astro<span class="tb">]</span></div>
        <h1 class="section-title">Build with Astro</h1>
        <p class="section-lead">
          Practical guides on building fast, low-maintenance websites with Astro,
          GitHub, and Cloudflare Pages. This entire site runs on this stack.
        </p>
        <div class="hero-stats">
          <div class="stat"><span class="stat-n">~€12</span><span class="stat-l">per year</span></div>
          <div class="stat-div">/</div>
          <div class="stat"><span class="stat-n">100</span><span class="stat-l">Lighthouse</span></div>
          <div class="stat-div">/</div>
          <div class="stat"><span class="stat-n">0</span><span class="stat-l">servers to patch</span></div>
        </div>
      </div>
    </section>

    <div class="section-body">

      <nav class="cat-nav" aria-label="Filter by category">
        {categories.map((cat, i) => (
          <button
            class={`cat-pill ${i === 0 ? 'active' : ''}`}
            data-tags={cat.tags.join(',')}
          >
            {cat.label}
          </button>
        ))}
      </nav>

      <section class="articles">
        {posts.length === 0 ? (
          <p class="empty">Articles publishing soon — subscribe to be notified.</p>
        ) : (
          <ul class="article-grid" id="article-grid" role="list">
            {posts.map(post => (
              <li data-tags={post.data.tags.join(',')}>
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  href={`/astro/${post.slug}`}
                  pubDate={post.data.pubDate}
                  tags={post.data.tags}
                  featured={post.data.featured}
                  section="astro"
                />
              </li>
            ))}
          </ul>
        )}
      </section>

      <section class="product-cta">
        <p class="cta-eyebrow"><span class="tb">[</span>newsletter<span class="tb">]</span></p>
        <h2 class="cta-title">Get notified when new articles land</h2>
        <p class="cta-body">No spam. Just an email when something new and useful goes up.</p>
        <a href="/#newsletter" class="btn-primary">Subscribe →</a>
      </section>

    </div>
  </main>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.cat-pill');
  const items = document.querySelectorAll<HTMLLIElement>('#article-grid li');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.dataset.tags ?? '';
      items.forEach(item => {
        if (!filter) { item.hidden = false; return; }
        const filterTags = filter.split(',');
        const postTags   = (item.dataset.tags ?? '').split(',');
        item.hidden = !filterTags.some(f => postTags.includes(f));
      });
    });
  });
</script>

<style>
  .section-page { max-width: var(--wide-w); margin: 0 auto; padding-bottom: 5rem; }

  /* Hero */
  .section-hero {
    position: relative; overflow: hidden;
    padding: 3rem 1.5rem 2.5rem;
    margin-bottom: 0;
  }
  .hero-photo {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    opacity: 0.18;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(126,184,212,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(126,184,212,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 100% at 30% 50%, black, transparent);
  }
  .hero-content { position: relative; z-index: 1; }
  .tag-label { font-family: var(--font-mono); font-size: 0.78rem; color: var(--amber); margin-bottom: 0.75rem; }
  .tb { opacity: 0.35; }
  .section-title { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: var(--text-bright); margin-bottom: 0.75rem; line-height: 1.1; }
  .section-lead { font-size: 1.05rem; color: var(--text-mid); max-width: 52ch; line-height: 1.7; margin-bottom: 1.75rem; }

  .hero-stats { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; align-items: center; }
  .stat-n { font-family: var(--font-mono); font-size: 1.7rem; color: var(--amber); line-height: 1; }
  .stat-l { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-dim); margin-top: 0.2rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-div { font-family: var(--font-mono); color: var(--amber-border); font-size: 1.4rem; }

  /* Body */
  .section-body { padding: 2.5rem 1.5rem 0; }

  /* Category pills */
  .cat-nav { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .cat-pill {
    padding: 0.35rem 0.85rem;
    font-family: var(--font-mono); font-size: 0.7rem;
    color: var(--text-dim); background: none;
    border: 1px solid var(--border-mid); border-radius: 100px;
    cursor: pointer; transition: all 0.15s; white-space: nowrap;
  }
  .cat-pill:hover { color: var(--amber); border-color: var(--amber-border); }
  .cat-pill.active { color: #18120a; background: var(--amber); border-color: var(--amber); }

  /* Grid */
  .articles { margin-bottom: 4rem; }
  .article-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
  .article-grid li[hidden] { display: none; }
  .empty { color: var(--text-dim); font-size: 0.9rem; }

  /* CTA */
  .product-cta { padding: 2.5rem; background: var(--bg2); border: 1px solid var(--amber-border); border-radius: 10px; }
  .cta-eyebrow { font-family: var(--font-mono); font-size: 0.72rem; color: var(--amber); margin-bottom: 0.5rem; }
  .cta-title { font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; color: var(--text-bright); margin-bottom: 0.75rem; }
  .cta-body { font-size: 0.93rem; color: var(--text-mid); line-height: 1.7; margin-bottom: 1.5rem; max-width: 54ch; }

  .btn-primary {
    display: inline-block; background: var(--amber); color: var(--bg);
    font-family: var(--font-mono); font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.08em; padding: 0.65rem 1.5rem; text-decoration: none;
    transition: background 0.15s;
  }
  .btn-primary:hover { background: #ffc13d; }
</style>
