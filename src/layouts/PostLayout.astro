---
// src/layouts/PostLayout.astro
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    pillar: string;
    type: string;
    tags: string[];
    readTime: number;
    heroImage?: string;
  };
  headings?: { depth: number; slug: string; text: string; }[];
}

const { frontmatter, headings = [] } = Astro.props;
const {
  title, description, pubDate, updatedDate,
  pillar, type, tags, readTime, heroImage
} = frontmatter;

const pillarColors: Record<string, string> = {
  'Infrastructure':   '#f0a500',
  'Self-Hosted AI':   '#7eb8d4',
  'Linux Automation': '#f0a500',
  'Monitoring':       '#c49a6c',
  'Security':         '#ff6b6b',
  'AWS Hybrid':       '#f0a500',
};
const color = pillarColors[pillar] ?? '#f0a500';

const formatDate = (d: Date) => new Date(d).toLocaleDateString('en-GB', {
  day: '2-digit', month: 'long', year: 'numeric'
});

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 2;
---

<BaseLayout title={title} description={description}>
  <article class="post-wrapper">

    <!-- Post Header — full width above the TOC layout -->
    <header class="post-header" style={`--post-color: ${color}`}>
      <div class="post-tags">
        <span class="tag-pill" style={`color:${color}; border-color:${color}44; background:${color}11`}>
          {pillar}
        </span>
        <span class="tag-pill tag-type">
          {type}
        </span>
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-desc">{description}</p>
      <div class="post-meta">
        <span>📅 {formatDate(pubDate)}</span>
        {updatedDate && <span>↻ Updated {formatDate(updatedDate)}</span>}
        <span>⏱ {readTime} min read</span>
      </div>
      <div class="post-header-rule"></div>
    </header>

    {heroImage && (
      <div class="post-hero">
        <img src={heroImage} alt={title} width="1200" height="630" loading="eager" />
      </div>
    )}

    <!-- Two-column layout: prose + sticky TOC -->
    <div class:list={['post-body-wrap', { 'has-toc': hasToc }]}>

      <!-- Main prose -->
      <div class="prose-content post-body">
        <slot />
      </div>

      <!-- Sticky TOC sidebar -->
      {hasToc && (
        <aside class="toc-sidebar">
          <TableOfContents headings={headings} />
        </aside>
      )}

    </div>

    <!-- Tags footer -->
    <footer class="post-footer">
      <div class="post-footer-tags">
        {tags.map(tag => (
          <a href={`/guides/tag/${tag}`} class="post-tag">#{tag}</a>
        ))}
      </div>
    </footer>

  </article>
</BaseLayout>

<style>
  /* ── Outer wrapper ─────────────────────────────────────────── */
  .post-wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 40px 80px;
  }
  @media (max-width: 600px) { .post-wrapper { padding: 28px 18px 60px; } }

  /* ── Header ────────────────────────────────────────────────── */
  .post-header { margin-bottom: 36px; }

  .post-tags { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .tag-pill {
    font-size: 10px; letter-spacing: 0.12em; font-weight: 700;
    padding: 3px 10px; border: 1px solid;
    font-family: var(--mono);
  }
  .tag-type { color: var(--text-dim); border-color: var(--border); background: transparent; }

  .post-title {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(26px, 4vw, 42px);
    color: var(--text-bright);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 14px;
  }

  .post-desc {
    color: var(--text-mid);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 16px;
    font-family: var(--sans);
    font-weight: 300;
    max-width: 680px;
  }

  .post-meta {
    display: flex; gap: 20px;
    font-size: 11px; color: var(--text-dim);
    flex-wrap: wrap;
    font-family: var(--mono);
    letter-spacing: 0.05em;
  }

  .post-header-rule {
    height: 1px;
    background: var(--border);
    margin-top: 24px;
  }

  /* ── Hero image ────────────────────────────────────────────── */
  .post-hero { margin-bottom: 36px; border: 1px solid var(--border); }
  .post-hero img { width: 100%; height: auto; display: block; }

  /* ── Body: prose + TOC layout ──────────────────────────────── */
  .post-body-wrap {
    display: block;
  }

  /* When TOC is present: two columns */
  .post-body-wrap.has-toc {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 60px;
    align-items: start;
  }

  /* ── TOC sidebar ───────────────────────────────────────────── */
  .toc-sidebar {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .toc-sidebar::-webkit-scrollbar { width: 3px; }
  .toc-sidebar::-webkit-scrollbar-thumb { background: var(--border); }

  /* On smaller screens, hide TOC sidebar */
  @media (max-width: 900px) {
    .post-body-wrap.has-toc {
      display: block;
    }
    .toc-sidebar { display: none; }
  }

  /* ── Prose styles ──────────────────────────────────────────── */
  .post-body {
    color: var(--text);
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.8;
    min-width: 0; /* prevents grid blowout */
  }

  .post-body :global(h2) {
    font-family: var(--display);
    font-weight: 600;
    color: var(--text-bright);
    font-size: clamp(20px, 2.5vw, 26px);
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    margin-top: 2.5em;
    margin-bottom: 0.8em;
    scroll-margin-top: 90px;
  }

  .post-body :global(h3) {
    font-family: var(--sans);
    font-weight: 600;
    color: var(--amber);
    font-size: 17px;
    margin-top: 2em;
    margin-bottom: 0.5em;
    scroll-margin-top: 90px;
  }

  .post-body :global(h4) {
    font-weight: 600;
    color: var(--text-bright);
    font-size: 15px;
    margin-top: 1.5em;
    margin-bottom: 0.4em;
  }

  .post-body :global(p) { margin-bottom: 1.3em; }

  .post-body :global(a) {
    color: var(--amber);
    border-bottom: 1px dashed var(--border-amber);
    transition: border-color 0.15s;
  }
  .post-body :global(a:hover) { border-bottom-color: var(--amber); }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.4em;
    margin-bottom: 1.3em;
  }
  .post-body :global(li) { margin-bottom: 0.5em; line-height: 1.7; }
  .post-body :global(li::marker) { color: var(--amber); }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--amber);
    padding: 12px 20px;
    margin: 1.5em 0;
    background: var(--amber-glow);
    color: var(--text-mid);
    font-style: italic;
    font-family: var(--display);
    font-size: 15px;
  }

  .post-body :global(strong) { color: var(--text-bright); font-weight: 600; }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5em 0;
  }

  /* Tables */
  .post-body :global(table) {
    border: 1px solid var(--border); width: 100%;
    margin: 1.5em 0; border-collapse: collapse;
    font-size: 14px; font-family: var(--mono);
  }
  .post-body :global(th) {
    background: var(--bg3); color: var(--amber);
    font-size: 10px; letter-spacing: 0.1em; font-weight: 700;
    padding: 10px 14px; text-align: left;
    border-bottom: 1px solid var(--border-amber);
  }
  .post-body :global(td) {
    padding: 10px 14px; border-bottom: 1px solid var(--border);
    font-size: 13px; color: var(--text); vertical-align: top;
    font-family: var(--sans);
  }
  .post-body :global(tr:last-child td) { border-bottom: none; }
  .post-body :global(tr:hover td) { background: rgba(240,165,0,0.03); }

  /* ── Post footer ───────────────────────────────────────────── */
  .post-footer {
    margin-top: 48px; padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .post-footer-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .post-tag {
    color: var(--text-dim); font-size: 11px; letter-spacing: 0.05em;
    border: 1px solid var(--border); padding: 2px 8px;
    transition: border-color 0.15s, color 0.15s;
    text-decoration: none; font-family: var(--mono);
  }
  .post-tag:hover { border-color: var(--amber); color: var(--amber); }
</style>
    <header class="post-header" style={`--post-color: ${color}`}>
      <div class="post-header-inner">
        <div class="post-tags">
          <span class="tag-pill" style={`color:${color}; border-color:${color}44; background:${color}11`}>
            {pillar}
          </span>
          <span class="tag-pill" style="color:#5a7a5a; border-color:#1a2e1a">
            {type}
          </span>
        </div>

        <h1 class="post-title">{title}</h1>
        <p class="post-desc">{description}</p>

        <div class="post-meta">
          <span>📅 {formatDate(pubDate)}</span>
          {updatedDate && <span>Updated: {formatDate(updatedDate)}</span>}
          <span>⏱ {readTime} min read</span>
        </div>
      </div>
      <div class="post-header-line"></div>
    </header>

    <!-- Optional hero image -->
    {heroImage && (
      <div class="post-hero">
        <img src={heroImage} alt={title} width="1200" height="630" loading="eager" />
      </div>
    )}

    <!-- Main prose content -->
    <div class="post-body prose prose-invert max-w-none">
      <slot />
    </div>

    <!-- Tags footer -->
    <footer class="post-footer">
      <div class="post-footer-tags">
        {tags.map(tag => (
          <a href={`/guides/tag/${tag}`} class="post-tag">#{tag}</a>
        ))}
      </div>
    </footer>

  </article>
</BaseLayout>

