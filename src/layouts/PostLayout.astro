---
// src/layouts/PostLayout.astro
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Comments from '../components/Comments.astro';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import type { MarkdownHeading } from 'astro';

interface Props {
  title:        string;
  description:  string;
  pubDate:      Date;
  updatedDate?: Date;
  heroImage?:   string;
  heroImageAlt?:string;
  tags?:        string[];
  readingTime?: number;
  section?:     'homelab' | 'astro' | 'aws';
  headings:     MarkdownHeading[];
  affiliate?:   boolean;
  noIndex?:     boolean;
  faqs?:        { q: string; a: string }[];
  slug?:        string;
}

const {
  title, description, pubDate, updatedDate,
  heroImage, heroImageAlt, tags = [], readingTime,
  section, headings, affiliate = false, noIndex = false, faqs, slug = '',
} = Astro.props;

const formatDate = (d: Date) => new Date(d).toLocaleDateString('en-GB', {
  day: '2-digit', month: 'long', year: 'numeric',
});

const sectionLabel = section === 'homelab' ? 'Homelab'
                   : section === 'astro'   ? 'Astro'
                   : section === 'aws'     ? 'AWS'
                   : 'Blog';
const sectionHref  = section === 'homelab' ? '/homelab'
                   : section === 'astro'   ? '/astro'
                   : section === 'aws'     ? '/aws'
                   : '/blog';

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const hasToc      = tocHeadings.length > 2;

const sectionColor = section === 'astro' ? '#7eb8d4'
                   : section === 'aws'   ? '#e8923a'
                   : '#f0a500';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const faqSchema = faqs?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a },
  })),
} : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": title,
  "description": description,
  "datePublished": new Date(pubDate).toISOString(),
  "dateModified": updatedDate ? new Date(updatedDate).toISOString() : new Date(pubDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Sergej Voronko",
    "url": "https://linuxcore.dev/about",
    "jobTitle": "SAP Basis Senior Operations Manager"
  },
  "publisher": {
    "@type": "Organization",
    "name": "linuxcore.dev",
    "url": "https://linuxcore.dev"
  },
  ...(heroImage && { "image": new URL(heroImage, Astro.site).toString() }),
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL.toString() }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://linuxcore.dev" },
    { "@type": "ListItem", "position": 2, "name": sectionLabel, "item": `https://linuxcore.dev${sectionHref}` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL.toString() }
  ]
};
---

<BaseLayout title={title} description={description} heroImage={heroImage} noIndex={noIndex}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <article class="post-wrapper">

    <header class="post-header" style={`--post-color: ${sectionColor}`}>
      <div class="post-tags">
        <span class="tag-pill" style={`color:${sectionColor}; border-color:${sectionColor}44; background:${sectionColor}11`}>
          {sectionLabel}
        </span>
        {readingTime && (
          <span class="tag-pill tag-type">{readingTime} min read</span>
        )}
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-desc">{description}</p>
      <div class="post-meta">
        <time datetime={new Date(pubDate).toISOString().slice(0, 10)}>{formatDate(pubDate)}</time>
        {updatedDate && <span>Updated {formatDate(updatedDate)}</span>}
        {tags.length > 0 && <span>{tags.slice(0,4).join(' · ')}</span>}
      </div>
      <div class="post-header-rule"></div>
    </header>

    {heroImage && (
      <div class="post-hero">
        <img src={heroImage} alt={heroImageAlt ?? title} width="1200" height="630" loading="eager" />
      </div>
    )}

    {affiliate && (
      <div class="affiliate-notice">
        <strong>Affiliate disclosure:</strong> This article contains affiliate links.
        If you buy through them, I earn a small commission at no extra cost to you.
        I only link to hardware and services I actually use or have tested.
      </div>
    )}

    <div class:list={['post-body-wrap', { 'has-toc': hasToc }]}>
      <div class="prose-content post-body">
        <slot />
        <ShareButtons title={title} />
      </div>

      {hasToc && (
        <aside class="toc-sidebar">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>

    {faqs?.length && (
      <section class="faq-section">
        <h2 class="faq-heading">Frequently Asked Questions</h2>
        <dl class="faq-list">
          {faqs.map(({ q, a }) => (
            <div class="faq-item">
              <dt class="faq-q">{q}</dt>
              <dd class="faq-a">{a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <RelatedPosts currentSlug={slug} currentTags={tags} section={section} />

    <NewsletterForm compact />

    <footer class="post-footer">
      <div class="post-footer-tags">
        {tags.map(tag => (
          <span class="post-tag">#{tag}</span>
        ))}
      </div>

      <div class="author-card">
        <img src="/images/avatar.webp" alt="Sergej Voronko" class="author-avatar" width="56" height="56" loading="lazy" />
        <div class="author-info">
          <div class="author-name">Sergej Voronko</div>
          <div class="author-role">SAP Basis · Senior Operations Manager · Linux infrastructure engineer</div>
          <a href="/about" class="author-link">About the author →</a>
        </div>
      </div>
    </footer>

  </article>

  <div class="comments-outer">
    <Comments />
  </div>
</BaseLayout>

<style>
  .post-wrapper {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 48px 40px 80px;
    overflow-x: clip;
  }
  .affiliate-notice {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    background: var(--bg2);
    border: 1px solid rgb(var(--amber-rgb) / 0.2);
    border-top: 2px solid var(--amber);
    padding: 0.75rem 1rem;
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  .affiliate-notice strong { color: var(--amber); }
  @media (max-width: 600px) { .post-wrapper { padding: 28px 18px 60px; } }

  /* ── Header ─── */
  .post-header { margin-bottom: 36px; }
  .post-tags { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .tag-pill {
    font-size: 12px; letter-spacing: 0.1em; font-weight: 700;
    padding: 3px 10px; border: 1px solid; font-family: var(--mono);
  }
  .tag-type { color: var(--text-dim); border-color: var(--border); background: transparent; }

  .post-title {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(26px, 4vw, 42px);
    color: var(--text-bright);
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 14px;
  }
  .post-desc {
    color: var(--text-mid); font-size: 16px; line-height: 1.7;
    margin-bottom: 16px; font-family: var(--sans); font-weight: 300;
    max-width: 680px;
  }
  .post-meta {
    display: flex; gap: 20px;
    font-size: 12px; color: var(--text-dim);
    flex-wrap: wrap; font-family: var(--mono); letter-spacing: 0.05em;
  }
  .post-header-rule { height: 1px; background: var(--border); margin-top: 24px; }

  /* ── Hero ─── */
  .post-hero { margin-bottom: 36px; border: 1px solid var(--border); }
  .post-hero img {
    width: 100%; height: auto; display: block;
    aspect-ratio: 1200 / 630; object-fit: cover;
  }
  @media (max-width: 600px) {
    .post-hero { margin-left: -18px; margin-right: -18px; border-left: none; border-right: none; }
  }

  /* ── Body / TOC layout ─── */
  .post-body-wrap { display: block; }
  .post-body-wrap.has-toc {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 60px;
    align-items: start;
  }
  @media (max-width: 900px) {
    .post-body-wrap.has-toc { display: block; }
    .toc-sidebar { display: none; }
  }

  .toc-sidebar {
    position: sticky; top: 80px;
    max-height: calc(100vh - 100px);
    overflow-y: hidden;
  }

  /* ── Prose ─── */
  .post-body {
    color: var(--text); font-family: var(--sans);
    font-size: 17px; line-height: 1.8; min-width: 0;
  }
  .post-body :global(h2) {
    font-family: var(--display); font-weight: 600;
    color: var(--text-bright); font-size: clamp(20px, 2.5vw, 26px);
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--border); padding-bottom: 10px;
    margin-top: 2.5em; margin-bottom: 0.8em; scroll-margin-top: 90px;
  }
  .post-body :global(h3) {
    font-family: var(--sans); font-weight: 600;
    color: var(--amber); font-size: 17px;
    margin-top: 2em; margin-bottom: 0.5em; scroll-margin-top: 90px;
  }
  .post-body :global(h4) {
    font-weight: 600; color: var(--text-bright); font-size: 15px;
    margin-top: 1.5em; margin-bottom: 0.4em;
  }
  .post-body :global(p) { margin-bottom: 1.3em; }
  .post-body :global(a) {
    color: var(--amber);
    border-bottom: 1px dashed var(--border-amber);
    transition: border-color 0.15s;
  }
  .post-body :global(a:hover) { border-bottom-color: var(--amber); }
  .post-body :global(ul),
  .post-body :global(ol) { padding-left: 1.4em; margin-bottom: 1.3em; }
  .post-body :global(li) { margin-bottom: 0.5em; line-height: 1.7; }
  .post-body :global(li::marker) { color: var(--amber); }
  .post-body :global(blockquote) {
    border: 1px solid rgb(var(--amber-rgb) / 0.2);
    border-top: 2px solid var(--amber);
    padding: 12px 20px;
    margin: 1.5em 0; background: var(--amber-glow);
    color: var(--text-mid); font-style: italic;
    font-family: var(--display); font-size: 15px;
  }
  .post-body :global(strong) { color: var(--text-bright); font-weight: 600; }
  .post-body :global(hr) { border: none; border-top: 1px solid var(--border); margin: 2.5em 0; }

  /* Code blocks — ensure horizontal scroll on narrow screens */
  .post-body :global(pre) {
    overflow-x: auto;
    max-width: 100%;
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 16px 20px;
    font-family: var(--mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--text);
    margin: 1.5em 0;
    -webkit-overflow-scrolling: touch;
  }
  .post-body :global(code) {
    font-family: var(--mono);
    font-size: 0.88em;
    color: var(--amber);
    background: rgb(var(--amber-rgb) / 0.08);
    padding: 2px 6px;
  }
  .post-body :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
    font-size: inherit;
  }
  .post-body :global(img) { max-width: 100%; border: 1px solid var(--border); }

  /* Tables */
  .post-body :global(table) {
    border: 1px solid var(--border); width: 100%;
    margin: 1.5em 0; border-collapse: collapse;
    font-size: 14px; font-family: var(--mono);
    display: block; overflow-x: auto; max-width: 100%;
  }
  .post-body :global(th) {
    background: var(--bg3); color: var(--amber);
    font-size: 12px; letter-spacing: 0.1em; font-weight: 700;
    padding: 10px 14px; text-align: left;
    border-bottom: 1px solid var(--border-amber);
  }
  .post-body :global(td) {
    padding: 10px 14px; border-bottom: 1px solid var(--border);
    font-size: 13px; color: var(--text); vertical-align: top;
    font-family: var(--sans);
  }
  .post-body :global(tr:last-child td) { border-bottom: none; }
  .post-body :global(tr:hover td) { background: rgb(var(--amber-rgb) / 0.03); }

  /* ── FAQ section ─── */
  .faq-section {
    margin-top: 56px;
    border-top: 1px solid var(--border);
    padding-top: 36px;
  }
  .faq-heading {
    font-family: var(--display); font-weight: 600;
    font-size: 20px; color: var(--text-bright);
    letter-spacing: -0.01em; margin-bottom: 24px;
  }
  .faq-list { display: flex; flex-direction: column; gap: 0; }
  .faq-item {
    border-bottom: 1px solid var(--border);
    padding: 18px 0;
  }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-q {
    font-family: var(--sans); font-weight: 600;
    font-size: 15px; color: var(--text-bright);
    margin-bottom: 8px; line-height: 1.4;
  }
  .faq-q::before {
    content: 'Q  ';
    font-family: var(--mono); font-size: 12px;
    font-weight: 700; letter-spacing: 0.1em;
    color: var(--amber); margin-right: 2px;
  }
  .faq-a {
    font-family: var(--sans); font-size: 15px;
    color: var(--text); line-height: 1.75;
    margin-left: 0; padding-left: 22px;
    color: var(--text-mid);
  }

  /* ── Post footer ─── */
  .post-footer { margin-top: 48px; padding-top: 20px; border-top: 1px solid var(--border); }
  .post-footer-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .post-tag {
    color: var(--text-dim); font-size: 12px; letter-spacing: 0.05em;
    border: 1px solid var(--border); padding: 2px 8px;
    transition: border-color 0.15s, color 0.15s; font-family: var(--mono);
  }
  .post-tag:hover { border-color: var(--amber); color: var(--amber); }

  /* ── Author card ─── */
  .author-card {
    display: flex; align-items: center; gap: 1rem;
    margin-top: 2rem; padding: 1.25rem;
    background: var(--bg2); border: 1px solid var(--border);
  }
  .author-avatar {
    width: 56px; height: 56px; border-radius: 50%; object-fit: cover; flex-shrink: 0;
  }
  .author-name { font-weight: 700; font-size: 0.95rem; color: var(--text-bright); margin-bottom: 0.2rem; }
  .author-role { font-family: var(--mono); font-size: 0.75rem; color: var(--text-dim); margin-bottom: 0.4rem; line-height: 1.5; }
  .author-link { font-family: var(--mono); font-size: 0.75rem; color: var(--amber); text-decoration: none; }
  .author-link:hover { text-decoration: underline; }

  /* ── Comments ─── */
  .comments-outer {
    width: 100%; max-width: 1100px; margin: 0 auto; padding: 0 40px 80px;
  }
  @media (max-width: 600px) { .comments-outer { padding: 0 18px 60px; } }
</style>
