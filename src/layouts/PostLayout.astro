---
// src/layouts/PostLayout.astro
// Wraps individual guide posts. Receives frontmatter via Astro.props.

import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    pillar: string;
    type: string;
    tags: string[];
    readTime: number;
    heroImage?: string;
  };
}

const { frontmatter } = Astro.props;
const {
  title, description, pubDate, updatedDate,
  pillar, type, tags, readTime, heroImage
} = frontmatter;

const pillarColors: Record<string, string> = {
  'Infrastructure':   '#00ff88',
  'Self-Hosted AI':   '#00e5ff',
  'Linux Automation': '#ffb300',
  'Monitoring':       '#b388ff',
  'Security':         '#ff4466',
  'AWS Hybrid':       '#ffb300',
};
const color = pillarColors[pillar] ?? '#00ff88';

const formatDate = (d: Date) => new Date(d).toLocaleDateString('en-GB', {
  day: '2-digit', month: 'long', year: 'numeric'
});
---

<BaseLayout title={title} description={description}>
  <article class="post-wrapper">

    <!-- Post Header -->
    <header class="post-header" style={`--post-color: ${color}`}>
      <div class="post-header-inner">
        <div class="post-tags">
          <span class="tag-pill" style={`color:${color}; border-color:${color}44; background:${color}11`}>
            {pillar}
          </span>
          <span class="tag-pill" style="color:#5a7a5a; border-color:#1a2e1a">
            {type}
          </span>
        </div>

        <h1 class="post-title">{title}</h1>
        <p class="post-desc">{description}</p>

        <div class="post-meta">
          <span>📅 {formatDate(pubDate)}</span>
          {updatedDate && <span>Updated: {formatDate(updatedDate)}</span>}
          <span>⏱ {readTime} min read</span>
        </div>
      </div>
      <div class="post-header-line"></div>
    </header>

    <!-- Optional hero image -->
    {heroImage && (
      <div class="post-hero">
        <img src={heroImage} alt={title} width="1200" height="630" loading="eager" />
      </div>
    )}

    <!-- Main prose content -->
    <div class="post-body prose prose-invert max-w-none">
      <slot />
    </div>

    <!-- Tags footer -->
    <footer class="post-footer">
      <div class="post-footer-tags">
        {tags.map(tag => (
          <a href={`/guides/tag/${tag}`} class="post-tag">#{tag}</a>
        ))}
      </div>
    </footer>

  </article>
</BaseLayout>

<style>
  .post-wrapper {
    max-width: 760px; margin: 0 auto;
    padding: 48px 40px 80px;
  }
  @media (max-width: 600px) { .post-wrapper { padding: 32px 20px 60px; } }

  .post-header { margin-bottom: 40px; }
  .post-tags { display: flex; gap: 8px; margin-bottom: 16px; flex-wrap: wrap; }
  .tag-pill { font-size: 10px; letter-spacing: 0.12em; font-weight: 700; padding: 3px 10px; border: 1px solid; }

  .post-title {
    font-family: var(--sans); font-weight: 800;
    font-size: clamp(24px, 4vw, 38px);
    color: var(--text-bright); line-height: 1.15;
    margin-bottom: 14px;
  }
  .post-desc { color: var(--text-dim); font-size: 15px; line-height: 1.7; margin-bottom: 16px; }
  .post-meta { display: flex; gap: 20px; font-size: 11px; color: var(--text-dim); flex-wrap: wrap; }
  .post-header-line { height: 1px; background: var(--border); margin-top: 24px; }

  .post-hero { margin-bottom: 36px; border: 1px solid var(--border); }
  .post-hero img { width: 100%; height: auto; display: block; }

  .post-body { color: var(--text); }
  /* Prose overrides for Tailwind Typography */
  .post-body :global(h2) {
    font-family: var(--sans); font-weight: 800;
    color: var(--text-bright); font-size: 22px;
    border-bottom: 1px solid var(--border); padding-bottom: 8px;
    margin-top: 40px;
  }
  .post-body :global(h3) {
    font-family: var(--sans); font-weight: 700;
    color: var(--text-bright); font-size: 17px; margin-top: 28px;
  }
  .post-body :global(table) {
    border: 1px solid var(--border); width: 100%;
  }
  .post-body :global(th) {
    background: var(--bg2); color: var(--green);
    font-size: 11px; letter-spacing: 0.1em;
    padding: 8px 12px; text-align: left;
    border-bottom: 1px solid var(--border);
  }
  .post-body :global(td) {
    padding: 8px 12px; border-bottom: 1px solid var(--border);
    font-size: 13px;
  }

  .post-footer { margin-top: 48px; padding-top: 20px; border-top: 1px solid var(--border); }
  .post-footer-tags { display: flex; gap: 8px; flex-wrap: wrap; }
  .post-tag {
    color: var(--text-dim); font-size: 11px; letter-spacing: 0.05em;
    border: 1px solid var(--border); padding: 2px 8px;
    transition: border-color 0.15s, color 0.15s;
    text-decoration: none;
  }
  .post-tag:hover { border-color: var(--green); color: var(--green); }
</style>
